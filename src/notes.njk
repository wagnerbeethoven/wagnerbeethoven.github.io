---
layout: layouts/base.njk
title: Notas
pagination:
  data: collections.notes
  size: 20
  alias: items
  reverse: true
permalink: "/notes/{% if pagination.pageNumber > 0 %}page-{{ pagination.pageNumber + 1 }}/{% endif %}"
showUpdated: true
---
<section class="page-hero">
  <div class="page-hero-inner page-hero-inner--editorial">
    <div class="editorial-bar">
      <a href="/" class="editorial-back" aria-label="Voltar para a pagina inicial"><i class="fa-solid fa-chevron-left" aria-hidden="true"></i></a>
      <div class="editorial-brand">
        <p class="editorial-site">{{ site.name }}</p>
        <p class="editorial-hello">Observações rápidas e fragmentos</p>
      </div>
    </div>
  </div>
</section>

<section class="content-frame">
  <div class="content-surface">
    <header class="entry-header-card">
      {% set breadcrumb = [{label: "Notas"}] %}
      {% include "partials/breadcrumb.njk" %}
      <h1 class="entry-title">Notas</h1>
      <p class="entry-summary">Observações curtas, fragmentos e ideias que pedem pouco contexto.</p>
      {%- include "partials/last-updated.njk" %}
    </header>

    {% set items = items | default([]) %}
    {% if items | length > 0 %}
    <div class="note-stream h-feed">
      {% for item in items %}
      <article class="note-card h-entry">
        <a class="u-url hidden" href="{{ site.url }}{{ item.url }}">Permalink</a>
        <span class="sr-only p-author h-card">
          <a class="p-name u-url" href="{{ site.url }}" rel="me">{{ site.author }}</a>
        </span>
        <div class="note-card-header">
          <img class="note-card-avatar" src="/assets/profile.jpg" alt="{{ site.author }}" width="40" height="40" loading="lazy">
          <div class="note-card-identity">
            <span class="note-card-name">{{ site.author }}</span>
            <a class="note-card-handle u-url" href="{{ item.url }}">
              <time class="dt-published" datetime="{{ item.date | htmlDateString }}">{{ item.date | readableDate("dd MMM yyyy") }}</time>
            </a>
          </div>
        </div>
        <div class="note-card-body e-content prose">{{ item.templateContent | safe }}</div>
        {% if item.data.tags and item.data.tags | length %}
        <div class="note-card-footer">
          {% for tag in item.data.tags %}{% if tag != "notes" %}<a class="pill p-category" href="/tags/{{ tag | slug }}/">{{ tag }}</a>{% endif %}{% endfor %}
        </div>
        {% endif %}
      </article>
      {% endfor %}
    </div>
    {% else %}
    <div class="empty-card">Ainda não há notas publicadas.</div>
    {% endif %}

    <nav class="utility-row mt-4" aria-label="Paginação">
      {% if pagination.href.previous %}
      <a class="soft-link" href="{{ pagination.href.previous }}">Mais recentes</a>
      {% else %}<span></span>{% endif %}
      {% if pagination.href.next %}
      <a class="soft-link" href="{{ pagination.href.next }}">Mais antigas</a>
      {% endif %}
    </nav>
  </div>
</section>
