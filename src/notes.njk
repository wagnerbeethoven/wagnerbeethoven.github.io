---
layout: layouts/base.njk
title: Notas
pagination:
  data: collections.notes
  size: 20
  alias: items
  reverse: true
permalink: "/notes/{% if pagination.pageNumber > 0 %}page-{{ pagination.pageNumber + 1 }}/{% endif %}"
---
<section class="page-hero">
  <div class="page-hero-inner page-hero-inner--editorial">
    <div class="editorial-bar">
      <a href="/" class="editorial-back" aria-label="Voltar para a pagina inicial"><i class="fa-solid fa-chevron-left" aria-hidden="true"></i></a>
      <div class="editorial-brand">
        <p class="editorial-site">{{ site.name }}</p>
        <p class="editorial-hello">Observações rápidas e fragmentos</p>
      </div>
    </div>
  </div>
</section>

<section class="content-frame">
  <div class="content-surface">
    <header class="entry-header-card">
      {% set breadcrumb = [{label: "Notas"}] %}
      {% include "partials/breadcrumb.njk" %}
      <h1 class="entry-title">Notas</h1>
      <p class="entry-summary">Observações curtas, fragmentos e ideias que pedem pouco contexto.</p>
    </header>

    {% set items = items | default([]) %}
    {% if items | length > 0 %}
    <div class="note-stream">
      {% for item in items %}
      <article class="note-entry h-entry">
        <div class="note-entry-meta">
          <time class="dt-published" datetime="{{ item.date | htmlDateString }}">{{ item.date | readableDate }}</time>
          {% if item.data.title %}
          <span aria-hidden="true">·</span>
          <a class="u-url" href="{{ item.url }}">{{ item.data.title }}</a>
          {% endif %}
        </div>
        <div class="e-content prose">{{ item.templateContent | safe }}</div>
      </article>
      {% endfor %}
    </div>
    {% else %}
    <div class="empty-card">Ainda não há notas publicadas.</div>
    {% endif %}

    <nav class="utility-row mt-4" aria-label="Paginação">
      {% if pagination.href.previous %}
      <a class="soft-link" href="{{ pagination.href.previous }}">Mais recentes</a>
      {% else %}<span></span>{% endif %}
      {% if pagination.href.next %}
      <a class="soft-link" href="{{ pagination.href.next }}">Mais antigas</a>
      {% endif %}
    </nav>
  </div>
</section>
