---
layout: layouts/base.njk
permalink: "/series/"
title: Séries
---
<section class="page-hero">
  <div class="page-hero-inner page-hero-inner--editorial">
    <div class="editorial-bar">
      <a href="/" class="editorial-back" aria-label="Voltar para a página inicial"><i class="fa-solid fa-chevron-left" aria-hidden="true"></i></a>
      <div class="editorial-brand">
        <p class="editorial-site">{{ site.name }}</p>
        <p class="editorial-hello">Séries e o que acompanho</p>
      </div>
    </div>
  </div>
</section>

<section class="content-frame">
  <div class="content-surface">
    <header class="entry-header-card">
      {% set breadcrumb = [{label: "Séries"}] %}
      {% include "partials/breadcrumb.njk" %}
      <h1 class="entry-title">Séries</h1>
      <p class="entry-summary">O que estou acompanhando, o que já terminei e o que ainda quero ver.</p>
    </header>

    {% set allSeries = collections.series | default([]) %}
    {% if allSeries | length > 0 %}
    <div class="media-grid">
      {% for item in allSeries %}
      <a href="{{ item.url }}" class="media-card" aria-label="{{ item.data.title }}">
        <div class="media-card-poster">
          {% if item.data.image %}
            <img src="{{ item.data.image }}" alt="" loading="lazy">
          {% elif item.data.poster %}
            <img src="{{ item.data.poster }}" alt="" loading="lazy">
          {% else %}
            📺
          {% endif %}
          {% if item.data.status == 'done' %}<span class="media-badge media-badge--done">Assistida</span>
          {% elif item.data.status == 'watching' %}<span class="media-badge media-badge--watching">Assistindo</span>
          {% endif %}
          <span class="media-card-cover-label">{{ item.data.title }}</span>
        </div>
      </a>
      {% endfor %}
    </div>
    {% else %}
    <div class="empty-card">Nenhuma série ainda.</div>
    {% endif %}
  </div>
</section>
