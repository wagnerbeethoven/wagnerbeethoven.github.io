---
layout: layouts/base.njk
permalink: "/archive/"
title: Arquivo
---
<section class="page-hero">
  <div class="page-hero-inner">
    {% set breadcrumb = [{label: "Arquivo"}] %}
      {% include "partials/breadcrumb.njk" %}
    <h1 class="page-title">Arquivo do blog</h1>
    <p class="page-subtitle">
      {% set total = collections.posts | default([]) | length %}
      {{ total }} post{% if total != 1 %}s{% endif %} publicado{% if total != 1 %}s{% endif %}, organizados por ano e mes.
    </p>
  </div>
</section>

<section class="content-frame">
  <div class="content-surface">

    {% if collections.archiveTree and collections.archiveTree.length > 0 %}

      {% for year in collections.archiveTree %}
      <section class="{% if not loop.first %}mt-10 pt-8 border-t border-[var(--border-subtle)]{% endif %}">
        <div class="flex items-baseline justify-between mb-5">
          <h2 class="text-2xl font-extrabold">{{ year.year }}</h2>
          <span class="sidebar-count">{{ year.count }} post{% if year.count != 1 %}s{% endif %}</span>
        </div>

        {% for month in year.months %}
        <div class="mb-7" id="{{ year.year }}-{{ month.key }}">
          <h3 class="text-sm font-bold text-[var(--text-secondary)] uppercase tracking-widest mb-3">
            <a href="#{{ year.year }}-{{ month.key }}" class="hover:text-[var(--accent)]">{{ month.label }}</a>
          </h3>
          <div class="sidebar-list pl-3 border-l-2 border-[var(--border-subtle)]">
            {% for post in month.posts %}
            <a href="{{ post.url }}" class="sidebar-link">
              {{ post.data.title }}
              {% if post.data.tags and post.data.tags.length > 0 %}
              <span class="sidebar-count">
                {% for tag in post.data.tags %}#{{ tag }} {% endfor %}
              </span>
              {% endif %}
            </a>
            {% endfor %}
          </div>
        </div>
        {% endfor %}
      </section>
      {% endfor %}

    {% else %}
      <p class="text-[var(--text-secondary)]">Ainda nao ha posts no arquivo.</p>
    {% endif %}

  </div>
</section>
