---
layout: layouts/base.njk
title: Livros
permalink: /bookshelf/
---
<section class="page-hero">
  <div class="page-hero-inner page-hero-inner--editorial">
    <div class="editorial-bar">
      <a href="/" class="editorial-back" aria-label="Voltar para a pagina inicial"><i class="fa-solid fa-chevron-left" aria-hidden="true"></i></a>
      <div class="editorial-brand">
        <p class="editorial-site">{{ site.name }}</p>
        <p class="editorial-hello">Leituras e referências</p>
      </div>
    </div>
  </div>
</section>

<section class="content-frame">
  <div class="content-surface">
    <header class="entry-header-card">
      {% set breadcrumb = [{label: "Livros"}] %}
      {% include "partials/breadcrumb.njk" %}
      <h1 class="entry-title">Livros</h1>
      <p class="entry-summary">Um espaço para registrar leituras, releituras e notas de percurso.</p>
    </header>

    {% set allBooks = collections.books | default([]) %}
    {% if allBooks | length > 0 %}
    <div class="book-grid book-grid--4">
      {% for item in allBooks %}
      <a href="{{ item.url }}" class="book-card">
        <div class="book-cover-wrap">
          {% if item.data.isbn %}
          <img class="book-card-cover"
            src="https://covers.openlibrary.org/b/isbn/{{ item.data.isbn }}-M.jpg"
            alt="Capa de {{ item.data.title }}"
            loading="lazy"
            onerror="this.style.background='var(--bg-hero)';this.removeAttribute('src')" />
          {% else %}
          <div class="book-card-cover" style="background:var(--bg-hero);display:flex;align-items:center;justify-content:center;font-size:2rem;">📖</div>
          {% endif %}
          {% if item.data.status == 'reading' %}<span class="media-badge media-badge--watching">Lendo</span>
          {% elif item.data.status == 'read' %}<span class="media-badge media-badge--done">Lido</span>
          {% elif item.data.status == 'want' %}<span class="media-badge media-badge--want">Para ler</span>
          {% endif %}
        </div>
        <p class="book-card-title">{{ item.data.title }}</p>
        <p class="book-card-author">{{ item.data.author }}</p>
      </a>
      {% endfor %}
    </div>
    {% else %}
    <div class="empty-card">Nenhum livro ainda.</div>
    {% endif %}
  </div>
</section>
