---
layout: layouts/base.njk
title: Livros
permalink: /bookshelf/
---
<section class="page-hero">
  <div class="page-hero-inner page-hero-inner--editorial">
    <div class="editorial-bar">
      <a href="/" class="editorial-back" aria-label="Voltar para a página inicial"><i class="fa-solid fa-chevron-left" aria-hidden="true"></i></a>
      <div class="editorial-brand">
        <p class="editorial-site">{{ site.name }}</p>
        <p class="editorial-hello">Leituras e referências</p>
      </div>
    </div>
  </div>
</section>

<section class="content-frame">
  <div class="content-surface">
    <header class="entry-header-card">
      {% set breadcrumb = [{label: "Livros"}] %}
      {% include "partials/breadcrumb.njk" %}
      <h1 class="entry-title">Livros</h1>
      {% include "partials/page-summary.njk" %}
    </header>

    {% set allBooks = collections.bookshelf | default([]) %}
    {% if allBooks | length > 0 %}
    <div class="home-blog-list h-feed">
      {% for item in allBooks %}
      <a href="{{ item.url }}" class="home-blog-row h-entry">
        <div class="home-blog-row-main">
          <span class="home-blog-row-title p-name">{{ item.data.title }}{% if item.data.author %} / {{ item.data.author }}{% endif %}</span>
        </div>
        <time class="home-blog-row-date dt-published" datetime="{{ item.date | htmlDateString }}">{{ item.date | shortDate }}</time>
      </a>
      {% endfor %}
    </div>
    {% else %}
    <div class="empty-card">Nenhum livro ainda.</div>
    {% endif %}
  </div>
</section>
