---
layout: layouts/base.njk
title: Livros
permalink: /bookshelf/
showUpdated: true
---
<section class="page-hero">
  <div class="page-hero-inner page-hero-inner--editorial">
    <div class="editorial-bar">
      <a href="/" class="editorial-back" aria-label="Voltar para a página inicial"><i class="fa-solid fa-chevron-left" aria-hidden="true"></i></a>
      <div class="editorial-brand">
        <p class="editorial-site">{{ site.name }}</p>
        <p class="editorial-hello">Leituras e referências</p>
      </div>
    </div>
  </div>
</section>

<section class="content-frame">
  <div class="content-surface">
    <header class="entry-header-card">
      {% set breadcrumb = [{label: "Livros"}] %}
      {% include "partials/breadcrumb.njk" %}
      <h1 class="entry-title">Livros</h1>
      <p class="entry-summary">Um espaço para registrar leituras, releituras e notas de percurso.</p>
      {%- include "partials/last-updated.njk" %}
    </header>

    {% set allBooks = collections.bookshelf | default([]) %}
    {% if allBooks | length > 0 %}
    <div class="media-grid">
      {% for item in allBooks %}
      <a href="{{ item.url }}" class="media-card" aria-label="{{ item.data.title }}{% if item.data.author %} — {{ item.data.author }}{% endif %}">
        <div class="media-card-poster">
          {% if item.data.image %}
            <img src="{{ item.data.image }}" alt="" loading="lazy">
          {% elif item.data.isbn %}
            <img src="https://covers.openlibrary.org/b/isbn/{{ item.data.isbn }}-M.jpg" alt="" loading="lazy"
                 onerror="this.parentElement.innerHTML='<span style=\'font-size:2.5rem\'>📖</span>'">
          {% else %}
            📖
          {% endif %}
          {% if item.data.status == 'reading' %}<span class="media-badge media-badge--watching">Lendo</span>
          {% elif item.data.status == 'read' %}<span class="media-badge media-badge--done">Lido</span>
          {% endif %}
          <span class="media-card-cover-label">{{ item.data.title }}{% if item.data.author %}<br><span style="font-weight:400;opacity:.85">{{ item.data.author }}</span>{% endif %}</span>
        </div>
      </a>
      {% endfor %}
    </div>
    {% else %}
    <div class="empty-card">Nenhum livro ainda.</div>
    {% endif %}
  </div>
</section>
