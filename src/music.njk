---
layout: layouts/base.njk
permalink: "/music/"
title: Música
---
<section class="page-hero">
  <div class="page-hero-inner page-hero-inner--editorial">
    <div class="editorial-bar">
      <a href="/" class="editorial-back" aria-label="Voltar para a pagina inicial"><i class="fa-solid fa-chevron-left" aria-hidden="true"></i></a>
      <div class="editorial-brand">
        <p class="editorial-site">{{ site.name }}</p>
        <p class="editorial-hello">O que estou ouvindo</p>
      </div>
    </div>
  </div>
</section>

<section class="content-frame">
  <div class="content-surface">
    <header class="entry-header-card">
      {% set breadcrumb = [{label: "Música"}] %}
      {% include "partials/breadcrumb.njk" %}
      <h1 class="entry-title">Música</h1>
      <p class="entry-summary">Álbuns que marcaram, artistas que ficaram e o que está tocando agora.</p>
    </header>

    {% set allAlbums = collections.music | default([]) %}
    {% if allAlbums | length > 0 %}
    <div class="media-grid">
      {% for item in allAlbums %}
      <a href="{{ item.url }}" class="media-card">
        <div class="media-card-poster">
          {% if item.data.image %}
          <img src="{{ item.data.image }}" alt="Capa de {{ item.data.title }}" loading="lazy" />
          {% else %}
          🎵
          {% endif %}
          {% if item.data.rating %}
          <span class="media-badge media-badge--done">{{ item.data.rating }}★</span>
          {% endif %}
        </div>
        <div class="media-card-body">
          <p class="media-card-title">{{ item.data.title }}</p>
          {% if item.data.artist %}<p class="media-card-meta">{{ item.data.artist }}{% if item.data.year %} · {{ item.data.year }}{% endif %}</p>{% endif %}
          {% if item.data.note %}<p class="media-card-note">{{ item.data.note }}</p>{% endif %}
        </div>
      </a>
      {% endfor %}
    </div>
    {% else %}
    <div class="empty-card">Nenhum álbum ainda.</div>
    {% endif %}

    <div class="home-section-header" style="margin-top:2rem; padding-top:1rem; border-top:1px solid var(--border-subtle)">
      <h2 class="home-section-title">
        <i class="fa-solid fa-headphones" style="color:#d51007" aria-hidden="true"></i> Ouvindo recentemente
      </h2>
      <a href="https://www.last.fm/user/{{ site.lastfm.user }}" target="_blank" rel="noopener" class="home-section-more">Ver perfil →</a>
    </div>
    {% include "partials/lastfm-widget.njk" %}

  </div>
</section>
