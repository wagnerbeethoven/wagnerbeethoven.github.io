---
layout: layouts/base.njk
title: Poesias
pagination:
  data: collections.poetry
  size: 10
  alias: items
  reverse: true
permalink: "/poetry/{% if pagination.pageNumber > 0 %}page-{{ pagination.pageNumber + 1 }}/{% endif %}"
---
<section class="page-hero">
  <div class="page-hero-inner page-hero-inner--editorial">
    <div class="editorial-bar">
      <a href="/" class="editorial-back" aria-label="Voltar para a pagina inicial"><i class="fa-solid fa-chevron-left" aria-hidden="true"></i></a>
      <div class="editorial-brand">
        <p class="editorial-site">{{ site.name }}</p>
        <p class="editorial-hello">Textos em verso</p>
      </div>
    </div>
  </div>
</section>

<section class="content-frame">
  <div class="content-surface">
    <header class="entry-header-card">
      {% set breadcrumb = [{label: "Poesias"}] %}
      {% include "partials/breadcrumb.njk" %}
      <h1 class="entry-title">Poesias</h1>
      <p class="entry-summary">Textos curtos, fragmentos e poemas quando esse espaço pedir outra cadência.</p>
    </header>

    {% set items = items | default([]) %}
    {% if items | length > 0 %}
    <div class="home-grid home-grid-2">
      {% for item in items %}
      <a href="{{ item.url }}" class="entry-card h-entry">
        <p class="entry-card-title p-name">{{ item.data.title or 'Sem título' }}</p>
        <p class="entry-card-meta">
          {% if item.data.author %}<span>{{ item.data.author }}</span> · {% endif %}
          {% if item.date %}<time class="dt-published" datetime="{{ item.date | htmlDateString }}">{{ item.date | readableDate }}</time>{% endif %}
        </p>
        {% if item.templateContent %}
        <p class="entry-card-body">{{ item.templateContent | striptags | truncate(160) }}</p>
        {% elif item.data.description %}
        <p class="entry-card-body">{{ item.data.description }}</p>
        {% endif %}
      </a>
      {% endfor %}
    </div>
    {% else %}
    <div class="empty-card">Ainda não há poemas publicados.</div>
    {% endif %}

    <nav class="utility-row mt-4" aria-label="Paginação">
      {% if pagination.href.previous %}
      <a class="soft-link" href="{{ pagination.href.previous }}">Mais recentes</a>
      {% else %}<span></span>{% endif %}
      {% if pagination.href.next %}
      <a class="soft-link" href="{{ pagination.href.next }}">Mais antigas</a>
      {% endif %}
    </nav>
  </div>
</section>
