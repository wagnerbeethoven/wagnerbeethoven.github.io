---
permalink: /atom.xml
eleventyExcludeFromCollections: true
templateEngine: njk
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.name }}</title>
  <subtitle>{{ site.description }}</subtitle>
  <link href="{{ site.url }}/atom.xml" rel="self" type="application/atom+xml"/>
  <link href="{{ site.url }}/"/>
  <id>{{ site.url }}/</id>
  <author><name>{{ site.author }}</name></author>
  {%- set allItems = [] -%}
  {%- set allItems = allItems.concat(collections.posts | default([])) -%}
  {%- set allItems = allItems.concat(collections.notes | default([])) -%}
  {%- set allItems = allItems.concat(collections.poetry | default([])) -%}
  {%- set allItems = allItems.concat(collections.recipes | default([])) -%}
  {%- set feed = allItems | sort(true, false, "date") | slice(0, 30) -%}
  <updated>{% if feed | length %}{{ feed[0].date | htmlDateString }}T00:00:00Z{% else %}1970-01-01T00:00:00Z{% endif %}</updated>
  {% for item in feed %}
  <entry>
    <title>{{ item.data.title or (item.date | readableDate("dd/MM/yyyy")) }}</title>
    <link href="{{ site.url }}{{ item.url }}"/>
    <updated>{{ item.date | htmlDateString }}T00:00:00Z</updated>
    <id>{{ site.url }}{{ item.url }}</id>
    {% if item.data.description %}<summary>{{ item.data.description }}</summary>{% endif %}
    {% if item.templateContent %}<content type="html">{{ item.templateContent | htmlToAbsoluteUrls(site.url) }}</content>{% endif %}
  </entry>
  {% endfor %}
</feed>
