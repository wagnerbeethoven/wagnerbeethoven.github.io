---
layout: layouts/base.njk
title: Tags
permalink: /tags/
---
<section class="page-hero">
  <div class="page-hero-inner page-hero-inner--editorial">
    <div class="editorial-bar">
      <a href="/" class="editorial-back" aria-label="Voltar para a pagina inicial"><i class="fa-solid fa-chevron-left" aria-hidden="true"></i></a>
      <div class="editorial-brand">
        <p class="editorial-site">{{ site.name }}</p>
        <p class="editorial-hello">Temas e marcadores</p>
      </div>
    </div>
  </div>
</section>

<section class="content-frame">
  <div class="content-surface">
    <header class="entry-header-card">
      {% set breadcrumb = [{label: "Tags"}] %}
      {% include "partials/breadcrumb.njk" %}
      <h1 class="entry-title">Tags</h1>
      {% include "partials/page-summary.njk" %}
    </header>

    {% if collections.tagMeta and collections.tagMeta.length %}
    <div class="tag-index">
      {% for tag in collections.tagMeta %}
      <div class="tag-group" id="tag-{{ tag.name | slug }}">
        <h2 class="tag-group-title">
          <span class="tag-group-link">
            <span class="pill">#{{ tag.name }}</span>
          </span>
          <span class="tag-group-count">{{ tag.count }} {% if tag.count == 1 %}post{% else %}posts{% endif %}</span>
        </h2>
        {% if tag.posts %}
        <ul class="tag-post-list">
          {% for post in tag.posts %}
          <li class="tag-post-row">
            <time class="tag-post-date" datetime="{{ post.date | htmlDateString }}">{{ post.date | shortDate }}</time>
            <a class="tag-post-title" href="{{ post.url }}">
              {% if post.data.title %}
                {{ post.data.title }}
              {% elif post.data.excerpt %}
                <span class="archive-excerpt">{{ post.data.excerpt }}</span>
              {% elif post.data.images and post.data.images.length > 0 %}
                <span class="archive-excerpt">— imagem —</span>
              {% else %}
                <span class="archive-excerpt">—</span>
              {% endif %}
            </a>
          </li>
          {% endfor %}
        </ul>
        {% endif %}
      </div>
      {% endfor %}
    </div>
    {% else %}
    <p class="empty-card">Ainda não há tags publicadas.</p>
    {% endif %}
  </div>
</section>
