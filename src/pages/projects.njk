---
layout: layouts/base.njk
title: Projetos
permalink: /projects/
showUpdated: true
---
<section class="page-hero">
  <div class="page-hero-inner page-hero-inner--editorial">
    <div class="editorial-bar">
      <a href="/about/" class="editorial-back" aria-label="Voltar para sobre"><i class="fa-solid fa-chevron-left" aria-hidden="true"></i></a>
      <div class="editorial-brand">
        <p class="editorial-site">{{ site.name }}</p>
      </div>
    </div>
  </div>
</section>

<section class="content-frame">
  <div class="content-surface">
    <header class="entry-header-card">
      {% set breadcrumb = [{label: "Portfólio", url: "/portfolio/"}, {label: "Projetos"}] %}
      {% include "partials/breadcrumb.njk" %}
      <h1 class="entry-title">Projetos</h1>
      <p class="entry-summary">Projetos pessoais, experimentos e coisas que mantenho.</p>
    </header>

    <div class="project-stack">
      {% for project in projects %}
      <div class="project-stack-item">
        <div class="project-stack-meta">
          <h2 class="project-stack-title">{{ project.title }}</h2>
          {% if project.tags | length %}
          <div class="inline-pills">
            {% for tag in project.tags %}
            <span class="pill">#{{ tag }}</span>
            {% endfor %}
          </div>
          {% endif %}
        </div>
        {% set project = project %}
        {% include "partials/project-card.njk" %}
      </div>
      {% endfor %}
    </div>

    {% include "partials/last-updated.njk" %}
  </div>
</section>
