---
layout: layouts/base.njk
permalink: "/photos/"
title: Fotos
---
<section class="page-hero">
  <div class="page-hero-inner page-hero-inner--editorial">
    <div class="editorial-bar">
      <a href="/" class="editorial-back" aria-label="Voltar para a pagina inicial">
        <i class="fa-solid fa-chevron-left" aria-hidden="true"></i>
      </a>
      <div class="editorial-brand">
        <p class="editorial-site">{{ site.name }}</p>
      </div>
    </div>
  </div>
</section>

<section class="content-frame">
  <div class="content-surface">
    <header class="entry-header-card">
      {% set breadcrumb = [{ label: "Fotos" }] %}
      {% include "partials/breadcrumb.njk" %}
      <h1 class="entry-title">Fotos</h1>
      <p class="entry-summary">
        Fotos publicadas no <a href="https://pixelfed.com/wagnerbeethoven" class="icon-pixelfed" target="_blank" rel="noopener me">{% include "partials/icon-pixelfed.njk" %} Pixelfed</a> e sincronizadas automaticamente aqui.
      </p>
    </header>

    {% set allPhotos = collections.photos | default([]) %}
    {% if allPhotos | length > 0 %}
      <div class="polaroid-grid">
        {% for item in allPhotos %}
          <figure class="polaroid polaroid--clickable"
            role="button"
            tabindex="0"
            aria-label="Ampliar foto{{ ': ' + item.data.caption if item.data.caption else '' }}"
            data-img="{{ item.data.image }}"
            data-alt="{{ item.data.alt or item.data.title or '' }}"
            data-caption="{{ item.data.caption or '' }}">
            <img src="{{ item.data.image }}" alt="{{ item.data.alt or item.data.title }}" loading="lazy"/>
            <figcaption class="polaroid-caption">{{ item.data.caption }}</figcaption>
          </figure>
        {% endfor %}
      </div>
    {% else %}
      <div class="empty-card">Nenhuma foto ainda.</div>
    {% endif %}
  </div>
</section>

{% include "partials/lightbox.njk" %}
