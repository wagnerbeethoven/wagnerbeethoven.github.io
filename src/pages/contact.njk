---
layout: layouts/base.njk
permalink: "/contact/"
title: Contato
showUpdated: true
---
<section class="page-hero">
  <div class="page-hero-inner page-hero-inner--editorial">
    <div class="editorial-bar">
      <a href="/" class="editorial-back" aria-label="Voltar para a página inicial"><i class="fa-solid fa-chevron-left" aria-hidden="true"></i></a>
      <div class="editorial-brand">
        <p class="editorial-site">{{ site.name }}</p>
        <p class="editorial-hello">Entre em contato</p>
      </div>
    </div>
  </div>
</section>

<section class="content-frame">
  <div class="content-surface">
    <header class="entry-header-card">
      {% set breadcrumb = [{label: "Contato"}] %}
      {% include "partials/breadcrumb.njk" %}
      <h1 class="entry-title">Entre em contato</h1>
      {% include "partials/page-summary.njk" %}
    </header>

    <div class="uses-section" style="border-top:none;padding-top:0">
      <h2 class="uses-section-title"><i class="fa-solid fa-envelope" style="color:var(--accent)" aria-hidden="true"></i> Envie uma mensagem</h2>
      <form
        name="contato"
        method="POST"
        action="/contact/obrigado/"
        netlify
        netlify-honeypot="bot-field"
        class="contact-form"
        novalidate
      >
        <input type="hidden" name="form-name" value="contato">
        <p class="contact-form-honeypot" aria-hidden="true">
          <label>Não preencha: <input name="bot-field" tabindex="-1" autocomplete="off"></label>
        </p>

        <div class="contact-form-row">
          <div class="contact-form-group">
            <label class="contact-form-label" for="contact-name">Nome</label>
            <input type="text" id="contact-name" name="name" class="contact-form-input"
              placeholder="Seu nome" required autocomplete="name">
          </div>
          <div class="contact-form-group">
            <label class="contact-form-label" for="contact-email">E-mail</label>
            <input type="email" id="contact-email" name="email" class="contact-form-input"
              placeholder="seu@email.com" required autocomplete="email">
          </div>
        </div>

        <div class="contact-form-group">
          <label class="contact-form-label" for="contact-subject">Assunto</label>
          <input type="text" id="contact-subject" name="subject" class="contact-form-input"
            placeholder="Sobre o que você quer falar?">
        </div>

        <div class="contact-form-group">
          <label class="contact-form-label" for="contact-message">Mensagem</label>
          <textarea id="contact-message" name="message" class="contact-form-textarea"
            rows="6" placeholder="Escreva sua mensagem aqui..." required></textarea>
        </div>

        <div class="contact-form-footer">
          <button type="submit" class="contact-form-submit">
            <i class="fa-solid fa-paper-plane" aria-hidden="true"></i> Enviar mensagem
          </button>
          <p class="prose contact-form-hint">ou escreva direto para <a href="mailto:{{ site.email }}">{{ site.email }}</a></p>
        </div>
      </form>
    </div>

    <div class="uses-section">
      <h2 class="uses-section-title"><i class="fa-solid fa-address-book" style="color:#7ab87a" aria-hidden="true"></i> Contato direto</h2>
      <div class="resume-links-grid">
        {% set ids = ["email", "whatsapp", "telegram"] %}
        {% set variant = "resume-card" %}
        {% include "partials/site-links.njk" %}
      </div>
    </div>
  </div>
</section>
