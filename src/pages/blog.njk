---
layout: layouts/base.njk
pagination:
  data: collections.posts
  size: 10
  alias: posts
permalink: "/blog/{% if pagination.pageNumber > 0 %}page/{{ pagination.pageNumber + 1 }}/{% endif %}"
title: Blog
---
<section class="page-hero">
  <div class="page-hero-inner page-hero-inner--editorial">
    <div class="editorial-bar">
      <a href="/" class="editorial-back" aria-label="Voltar para a pagina inicial"><i class="fa-solid fa-chevron-left" aria-hidden="true"></i></a>
      <div class="editorial-brand">
        <p class="editorial-site">{{ site.name }}</p>
      </div>
    </div>
  </div>
</section>

<section class="content-frame">
  <div class="content-surface">
    <header class="entry-header-card">
      {% set breadcrumb = [{label: "Blog"}] %}
      {% include "partials/breadcrumb.njk" %}
      <h1 class="entry-title">Blog</h1>
      {% include "partials/page-summary.njk" %}
    </header>

    {% if posts | length > 0 %}
    <div class="home-blog-list h-feed">
      {% for post in posts %}
      <a href="{{ post.url }}" class="home-blog-row h-entry">
        <div class="home-blog-row-main">
          <span class="home-blog-row-title p-name">{{ post.data.title }}</span>
        </div>
        <time class="home-blog-row-date dt-published" datetime="{{ post.date | htmlDateString }}">{{ post.date | shortDate }}</time>
      </a>
      {% endfor %}
    </div>
    {% else %}
    <div class="empty-card">Ainda nÃ£o hÃ¡ artigos publicados.</div>
    {% endif %}

    {% set paginationLabel = "Paginação do blog" %}
    {% set paginationPrevLabel = "Mais recentes" %}
    {% set paginationNextLabel = "Mais antigos" %}
    {% include "partials/collection-pagination.njk" %}
  </div>
</section>
