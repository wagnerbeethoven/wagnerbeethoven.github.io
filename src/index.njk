---
layout: layouts/base.njk
permalink: "/"
---
<section class="page-hero">
  <div class="page-hero-inner">
    <h1 class="page-title">{{ site.name }}</h1>
    <p class="page-subtitle">Ola, sou {{ site.author }}. Isso aqui e um pedaco da internet que e meu.</p>
  </div>
</section>

<section class="content-frame" style="margin-top: 2rem">

  {# ── Blog — 1 por linha ────────────────────────────────── #}
  {% set recentPosts = collections.posts | default([]) | head(8) %}
  {% if recentPosts | length > 0 %}
  <div class="home-section" style="--section-tint:#e07b54">
    <div class="home-section-header">
      <h2 class="home-section-title"><i class="fa-solid fa-pen-nib" style="color:#e07b54" aria-hidden="true"></i> Blog</h2>
      <a href="/blog/" class="home-section-more">Ver todos →</a>
    </div>
    <div class="home-blog-list">
      {% for post in recentPosts %}
      <a href="{{ post.url }}" class="home-blog-row h-entry">
        <div class="home-blog-row-main">
          <span class="home-blog-row-title p-name">{{ post.data.title }}</span>
            {% if post.data.description %}<span class="home-blog-row-desc p-summary">{{ post.data.description }}</span>{% endif %}
        </div>
        <time class="home-blog-row-date dt-published" datetime="{{ post.date | htmlDateString }}">{{ post.date | shortDate }}</time>
      </a>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {# ── Notas — 2 colunas ─────────────────────────────────── #}
  {% set recentNotes = collections.notes | default([]) | head(8) %}
  {% if recentNotes | length > 0 %}
  <div class="home-section" style="--section-tint:#f0c040">
    <div class="home-section-header">
      <h2 class="home-section-title"><i class="fa-solid fa-note-sticky" style="color:#f0c040" aria-hidden="true"></i> Notas</h2>
      <a href="/notes/" class="home-section-more">Ver todas →</a>
    </div>
    <div class="note-stream">
      {% for item in recentNotes %}
      <article class="note-card h-entry">
        <a class="u-url hidden" href="{{ site.url }}{{ item.url }}">Permalink</a>
        <span class="sr-only p-author h-card">
          <a class="p-name u-url" href="{{ site.url }}" rel="me">{{ site.author }}</a>
        </span>
        <div class="note-card-header">
          <img class="note-card-avatar" src="/assets/profile.jpg" alt="{{ site.author }}" width="40" height="40" loading="lazy">
          <div class="note-card-identity">
            <span class="note-card-name">{{ site.author }}</span>
            <a class="note-card-handle u-url" href="{{ item.url }}">
              <time class="dt-published" datetime="{{ item.date | htmlDateString }}">{{ item.date | readableDate("dd MMM yyyy") }}</time>
            </a>
          </div>
        </div>
        <div class="note-card-body e-content prose">{{ item.templateContent | safe }}</div>
        {% if item.data.tags and item.data.tags | length %}
        <div class="note-card-footer">
          {% for tag in item.data.tags %}{% if tag != "notes" %}<a class="pill p-category" href="/tags/{{ tag | slug }}/">{{ tag }}</a>{% endif %}{% endfor %}
        </div>
        {% endif %}
      </article>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {# ── Fotos ─────────────────────────────────────────────── #}
  {% set recentPhotos = collections.photos | default([]) | head(4) %}
  {% if recentPhotos | length > 0 %}
  <div class="home-section" style="--section-tint:#e05c7a">
    <div class="home-section-header">
      <h2 class="home-section-title"><i class="fa-solid fa-camera" style="color:#e05c7a" aria-hidden="true"></i> Fotos</h2>
      <a href="/photos/" class="home-section-more">Ver todas →</a>
    </div>
    <div class="polaroid-grid">
      {% for photo in recentPhotos %}
      <figure class="polaroid">
        <img src="{{ photo.data.src }}" alt="{{ photo.data.alt or photo.data.caption }}" loading="lazy" />
        <figcaption class="polaroid-caption">{{ photo.data.caption or photo.data.alt }}</figcaption>
      </figure>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {# ── Poesia (último) ───────────────────────────────────── #}
  {% set latestPoem = collections.poetry | default([]) | head(1) %}
  {% if latestPoem | length > 0 %}
  {% set poem = latestPoem[0] %}
  <div class="home-section" style="--section-tint:#c47db8">
    <div class="home-section-header">
      <h2 class="home-section-title"><i class="fa-solid fa-feather-pointed" style="color:#c47db8" aria-hidden="true"></i> Poesia</h2>
      <a href="/poetry/" class="home-section-more">Ver todas →</a>
    </div>
    <a href="{{ poem.url }}" class="entry-card h-entry">
      <p class="entry-card-title p-name">{{ poem.data.title or 'Sem título' }}</p>
      <p class="entry-card-meta">
        {% if poem.data.author %}{{ poem.data.author }} · {% endif %}
        <time class="dt-published" datetime="{{ poem.date | htmlDateString }}">{{ poem.date | shortDate }}</time>
      </p>
      {% if poem.templateContent %}
      <p class="entry-card-body" style="font-style:italic;white-space:pre-line">{{ poem.templateContent | striptags | truncate(220) }}</p>
      {% endif %}
    </a>
  </div>
  {% endif %}

  {# ── Coleções ──────────────────────────────────────────── #}
  <div class="home-section home-section--plain">
    <div class="home-section-header">
      <h2 class="home-section-title"><i class="fa-solid fa-layer-group" style="color:#888" aria-hidden="true"></i> Explorar</h2>
    </div>
    <div class="home-collections-grid">
      {% set cnt = collections.posts | default([]) | length %}
      {% if cnt > 0 %}
      <a href="/blog/" class="home-collection-card">
        <i class="fa-solid fa-pen-nib" style="color:#e07b54" aria-hidden="true"></i>
        <span>Blog</span>
        <small>{{ cnt }}</small>
      </a>
      {% endif %}
      {% set cnt = collections.notes | default([]) | length %}
      {% if cnt > 0 %}
      <a href="/notes/" class="home-collection-card">
        <i class="fa-solid fa-note-sticky" style="color:#f0c040" aria-hidden="true"></i>
        <span>Notas</span>
        <small>{{ cnt }}</small>
      </a>
      {% endif %}
      {% set cnt = collections.poetry | default([]) | length %}
      {% if cnt > 0 %}
      <a href="/poetry/" class="home-collection-card">
        <i class="fa-solid fa-feather-pointed" style="color:#c47db8" aria-hidden="true"></i>
        <span>Poesias</span>
        <small>{{ cnt }}</small>
      </a>
      {% endif %}
      {% set cnt = collections.bookshelf | default([]) | length %}
      {% if cnt > 0 %}
      <a href="/bookshelf/" class="home-collection-card">
        <i class="fa-solid fa-book" style="color:#5b8dd9" aria-hidden="true"></i>
        <span>Livros</span>
        <small>{{ cnt }}</small>
      </a>
      {% endif %}
      {% set cnt = collections.movies | default([]) | length %}
      {% if cnt > 0 %}
      <a href="/movies/" class="home-collection-card">
        <i class="fa-solid fa-film" style="color:#e05c7a" aria-hidden="true"></i>
        <span>Filmes</span>
        <small>{{ cnt }}</small>
      </a>
      {% endif %}
      {% set cnt = collections.series | default([]) | length %}
      {% if cnt > 0 %}
      <a href="/series/" class="home-collection-card">
        <i class="fa-solid fa-tv" style="color:#5bc4c4" aria-hidden="true"></i>
        <span>Séries</span>
        <small>{{ cnt }}</small>
      </a>
      {% endif %}
      {% set cnt = collections.games | default([]) | length %}
      {% if cnt > 0 %}
      <a href="/games/" class="home-collection-card">
        <i class="fa-solid fa-gamepad" style="color:#7ab87a" aria-hidden="true"></i>
        <span>Jogos</span>
        <small>{{ cnt }}</small>
      </a>
      {% endif %}
      {% set cnt = collections.comics | default([]) | length %}
      {% if cnt > 0 %}
      <a href="/comics/" class="home-collection-card">
        <i class="fa-solid fa-book-open" style="color:#f0c040" aria-hidden="true"></i>
        <span>Quadrinhos</span>
        <small>{{ cnt }}</small>
      </a>
      {% endif %}
      {% set cnt = collections.recipes | default([]) | length %}
      {% if cnt > 0 %}
      <a href="/recipes/" class="home-collection-card">
        <i class="fa-solid fa-utensils" style="color:#e0a050" aria-hidden="true"></i>
        <span>Receitas</span>
        <small>{{ cnt }}</small>
      </a>
      {% endif %}
      {% set cnt = collections.photos | default([]) | length %}
      {% if cnt > 0 %}
      <a href="/photos/" class="home-collection-card">
        <i class="fa-solid fa-camera" style="color:#e05c7a" aria-hidden="true"></i>
        <span>Fotos</span>
        <small>{{ cnt }}</small>
      </a>
      {% endif %}
      {% set cnt = collections.music | default([]) | length %}
      {% if cnt > 0 %}
      <a href="/music/" class="home-collection-card">
        <i class="fa-solid fa-music" style="color:#d51007" aria-hidden="true"></i>
        <span>Música</span>
        <small>{{ cnt }}</small>
      </a>
      {% endif %}
    </div>
  </div>

</section>
