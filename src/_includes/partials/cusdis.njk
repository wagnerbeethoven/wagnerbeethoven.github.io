<section class="cusdis-section" aria-label="Comentários">
  <h2 class="cusdis-heading">
    <i class="fa-regular fa-comments" aria-hidden="true"></i> Comentários
  </h2>

  <div class="cusdis-engage">
    <p class="cusdis-engage-text">Tem algo a dizer sobre este texto? Algumas formas de responder:</p>
    <ul class="cusdis-engage-list">
      <li>
        <a href="mailto:{{ site.email }}?subject={{ title | urlencode }}" class="cusdis-engage-link">
          <i class="fa-solid fa-envelope" aria-hidden="true"></i>
          Mande um e-mail
        </a>
      </li>
      <li>
        <a href="https://bsky.app/profile/{{ site.social.bluesky }}" target="_blank" rel="noopener" class="cusdis-engage-link">
          <i class="fa-brands fa-bluesky" aria-hidden="true"></i>
          Comente no Bluesky
        </a>
      </li>
      <li>
        <a href="/guestbook/" class="cusdis-engage-link">
          <i class="fa-solid fa-book-open" aria-hidden="true"></i>
          Assine o livro de visitas
        </a>
      </li>
    </ul>
    <button
      class="cusdis-toggle-btn"
      aria-expanded="false"
      aria-controls="cusdis-widget"
      type="button"
    >
      <i class="fa-regular fa-comment-dots" aria-hidden="true"></i>
      <span>Deixar um comentário aqui</span>
      <i class="fa-solid fa-chevron-down cusdis-toggle-chevron" aria-hidden="true"></i>
    </button>
  </div>

  <div id="cusdis-widget" class="cusdis-widget" hidden aria-live="polite" aria-label="Seção de comentários">
    <div id="cusdis_thread"
      data-host="https://cusdis.com"
      data-app-id="eb72c89e-1a3c-456a-a8a3-3554a1facbfd"
      data-page-id="{{ page.url }}"
      data-page-url="{{ site.url }}{{ page.url }}"
      data-page-title="{{ title or (page.date | readableDate('dd MMM yyyy')) }}"
      data-lang="pt-BR"
      data-theme="auto"
    ></div>
  </div>

  <style>
    #cusdis_thread iframe {
      min-height: 420px;
      width: 100%;
      border: none;
      border-radius: 6px;
    }
    .cusdis-widget {
      margin-top: 1rem;
      padding: 1.25rem;
      border: 1px solid var(--border-subtle, #e0e0e0);
      border-radius: 8px;
    }
  </style>

  <script>
    // Tradução pt-BR via API do Cusdis (antes do script carregar)
    window.CUSDIS_LOCALE = {
      powered_by: 'Comentários via Cusdis',
      post_comment: 'Enviar',
      loading: 'Carregando…',
      email: 'E-mail',
      nickname: 'Nome',
      reply_placeholder: 'Escreva aqui…',
      reply_btn: 'Responder',
      sending: 'Enviando…',
      mod_badge: 'Moderador',
      content_is_required: 'O conteúdo é obrigatório',
      nickname_is_required: 'O nome é obrigatório',
      comment_has_been_sent: 'Comentário enviado, aguardando aprovação.',
    };
  </script>

  <script>
    (function () {
      var btn = document.querySelector('.cusdis-toggle-btn');
      var widget = document.getElementById('cusdis-widget');
      var thread = document.getElementById('cusdis_thread');
      var loaded = false;

      function syncTheme() {
        var dark = document.documentElement.getAttribute('data-theme') === 'dark'
          || document.documentElement.classList.contains('dark');
        thread.setAttribute('data-theme', dark ? 'dark' : 'light');
      }
      syncTheme();
      new MutationObserver(syncTheme).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme', 'class'] });

      btn.addEventListener('click', function () {
        var open = btn.getAttribute('aria-expanded') === 'true';
        if (!open) {
          widget.hidden = false;
          btn.setAttribute('aria-expanded', 'true');
          if (!loaded) {
            loaded = true;
            syncTheme();
            var s = document.createElement('script');
            s.src = 'https://cusdis.com/js/cusdis.es.js';
            s.async = true;
            s.defer = true;
            document.body.appendChild(s);
            s.onload = function () {
              if (window.CUSDIS && window.CUSDIS.renderTo) {
                window.CUSDIS.renderTo(thread);
              }
            };
          }
        } else {
          widget.hidden = true;
          btn.setAttribute('aria-expanded', 'false');
        }
      });
    })();
  </script>
</section>
