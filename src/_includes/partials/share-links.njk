<div class="share-row">
  <span class="share-row-label">Compartilhar</span>
  <a href="https://twitter.com/intent/tweet?url={{ site.url }}{{ page.url }}&text={{ title | urlencode }}"
     target="_blank" rel="noopener"
     class="share-icon-btn" aria-label="Compartilhar no X">
    <i class="fa-brands fa-x-twitter" style="color:#000" aria-hidden="true"></i>
  </a>
  <a href="https://www.linkedin.com/sharing/share-offsite/?url={{ site.url }}{{ page.url }}"
     target="_blank" rel="noopener"
     class="share-icon-btn" aria-label="Compartilhar no LinkedIn">
    <i class="fa-brands fa-linkedin" style="color:#0A66C2" aria-hidden="true"></i>
  </a>
  <a href="https://bsky.app/intent/compose?text={{ title | urlencode }}%20{{ site.url }}{{ page.url }}"
     target="_blank" rel="noopener"
     class="share-icon-btn" aria-label="Compartilhar no Bluesky">
    <i class="fa-brands fa-bluesky" style="color:#0085FF" aria-hidden="true"></i>
  </a>
  <a href="https://mastodon.social/share?text={{ title | urlencode }}%20{{ site.url }}{{ page.url }}"
     target="_blank" rel="noopener"
     class="share-icon-btn" aria-label="Compartilhar no Mastodon">
    <i class="fa-brands fa-mastodon" style="color:#6364FF" aria-hidden="true"></i>
  </a>
  <button class="share-chip js-share-btn"
          aria-label="Copiar link"
          data-share-title="{{ title }}"
          data-share-url="{{ site.url }}{{ page.url }}">
    <i class="fa-solid fa-link" style="color:var(--accent)" aria-hidden="true"></i> <span>Copiar link</span>
  </button>
</div>
