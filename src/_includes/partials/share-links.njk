<div class="share-row">
  <span class="share-row-label">Compartilhar</span>
  <a href="https://twitter.com/intent/tweet?url={{ site.url }}{{ page.url }}&text={{ title | urlencode }}"
     target="_blank" rel="noopener"
     class="share-icon-btn" aria-label="Compartilhar no X" style="background:#000;color:#fff">
    <i class="fa-brands fa-x-twitter" aria-hidden="true"></i>
  </a>
  <a href="https://www.linkedin.com/sharing/share-offsite/?url={{ site.url }}{{ page.url }}"
     target="_blank" rel="noopener"
     class="share-icon-btn" aria-label="Compartilhar no LinkedIn" style="background:#0A66C2;color:#fff">
    <i class="fa-brands fa-linkedin" aria-hidden="true"></i>
  </a>
  <a href="https://bsky.app/intent/compose?text={{ title | urlencode }}%20{{ site.url }}{{ page.url }}"
     target="_blank" rel="noopener"
     class="share-icon-btn" aria-label="Compartilhar no Bluesky" style="background:#0085FF;color:#fff">
    <i class="fa-brands fa-bluesky" aria-hidden="true"></i>
  </a>
  <a href="https://mastodon.social/share?text={{ title | urlencode }}%20{{ site.url }}{{ page.url }}"
     target="_blank" rel="noopener"
     class="share-icon-btn" aria-label="Compartilhar no Mastodon" style="background:#6364FF;color:#fff">
    <i class="fa-brands fa-mastodon" aria-hidden="true"></i>
  </a>
  <button class="share-chip js-share-btn"
          aria-label="Copiar link"
          data-share-title="{{ title }}"
          data-share-url="{{ site.url }}{{ page.url }}">
    <i class="fa-solid fa-link" style="color:var(--accent)" aria-hidden="true"></i> <span>Copiar link</span>
  </button>
</div>
