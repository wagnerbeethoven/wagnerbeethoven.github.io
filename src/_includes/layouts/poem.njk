---
layout: layouts/base.njk
---
<section class="page-hero">
  <div class="page-hero-inner page-hero-inner--editorial">
    <div class="editorial-bar">
      <a href="/poetry/" class="editorial-back" aria-label="Voltar para poesias"><i class="fa-solid fa-chevron-left" aria-hidden="true"></i></a>
      <div class="editorial-brand">
        <p class="editorial-site">{{ site.name }}</p>
      </div>
    </div>
  </div>
</section>

<section class="content-frame">
  <div class="content-surface">
    <article class="h-entry">
      <header class="entry-header-card">
        {% set breadcrumb = [{label: "Poesias", url: "/poetry/"}, {label: title}] %}
        {% include "partials/breadcrumb.njk" %}
        <h1 class="entry-title p-name">{{ title }}</h1>
        <p class="entry-meta">
          {% if author %}<strong class="p-author">{{ author }}</strong> {% if source %}em  <span class="entry-meta-source">{{ source }}</span>{% endif %}{% endif %}
          {# {% if page.date %}<p><time class="dt-published" datetime="{{ page.date | htmlDateString }}">{{ page.date | relativeDate }}</time></p>{% endif %} #}
        </p>
        <a class="u-url hidden" href="{{ page.url }}">Permalink</a>
      </header>
      <div class="e-content prose">
        {{ content | safe }}
      </div>
    </article>
  </div>
</section>
