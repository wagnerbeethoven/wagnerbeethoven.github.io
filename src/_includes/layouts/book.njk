---
layout: layouts/base.njk
---
<section class="page-hero">
  <div class="page-hero-inner page-hero-inner--editorial">
    <div class="editorial-bar">
      <a href="/bookshelf/" class="editorial-back" aria-label="Voltar para livros"><i class="fa-solid fa-chevron-left" aria-hidden="true"></i></a>
      <div class="editorial-brand">
        <p class="editorial-site">{{ site.name }}</p>
        <p class="editorial-hello">Livros</p>
      </div>
    </div>
  </div>
</section>

<section class="content-frame">
  <div class="content-surface media-page">
    <header class="entry-header-card">
      {% set breadcrumb = [{label: "Livros", url: "/bookshelf/"}, {label: title}] %}
      {% include "partials/breadcrumb.njk" %}
      <h1 class="entry-title">{{ title }}</h1>
      {% if author %}<p class="media-page-subtitle">{{ author }}</p>{% endif %}
    </header>

    <div class="media-detail">
      <div class="media-poster">
        {% if image %}
          <img src="{{ image }}" alt="Capa de {{ title }}" class="media-poster-img" loading="lazy">
        {% elif isbn %}
          <img src="https://covers.openlibrary.org/b/isbn/{{ isbn }}-L.jpg"
               alt="Capa de {{ title }}" class="media-poster-img" loading="lazy"
               onerror="this.parentElement.innerHTML='<div class=\'media-poster-placeholder\'>📚</div>'" />
        {% else %}
          <div class="media-poster-placeholder" aria-hidden="true">📚</div>
        {% endif %}
      </div>

      <div class="media-detail-info">
        <dl class="media-meta">
          {% if author %}<div class="media-meta-wide"><dt>Autor</dt><dd>{{ author }}</dd></div>{% endif %}
          {% if publisher %}<div class="media-meta-wide"><dt>Editora</dt><dd>{{ publisher }}</dd></div>{% endif %}
          {% if year %}<div><dt>Ano</dt><dd>{{ year }}</dd></div>{% endif %}
          {% if pages %}<div><dt>Páginas</dt><dd>{{ pages }}</dd></div>{% endif %}
          {% if isbn %}<div><dt>ISBN</dt><dd>{{ isbn }}</dd></div>{% endif %}
        </dl>

        {% if tags %}
          <ul class="inline-pills" aria-label="Tags">
            {% for tag in tags %}
              <li><a class="pill p-category" href="/tags/{{ tag | slug }}/">{{ tag }}</a></li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>
    </div>

    {% if note %}<p class="media-note">{{ note }}</p>{% endif %}
    {% if content %}<div class="prose">{{ content | safe }}</div>{% endif %}

    {% include "partials/share-links.njk" %}
  </div>
</section>
