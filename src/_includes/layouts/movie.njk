---
layout: layouts/base.njk
---
<section class="page-hero">
  <div class="page-hero-inner page-hero-inner--editorial">
    <div class="editorial-bar">
      <a href="/movies/" class="editorial-back" aria-label="Voltar para filmes"><i class="fa-solid fa-chevron-left" aria-hidden="true"></i></a>
      <div class="editorial-brand">
        <p class="editorial-site">{{ site.name }}</p>
        <p class="editorial-hello">Filmes</p>
      </div>
    </div>
  </div>
</section>

<div class="content-surface">
  <nav class="breadcrumb" aria-label="Navegação estrutural">
    <ol class="breadcrumb-list">
      <li class="breadcrumb-item"><a href="/">Início</a></li>
      <li class="breadcrumb-item"><a href="/movies/">Filmes</a></li>
      <li class="breadcrumb-item breadcrumb-item--current" aria-current="page">{{ title }}</li>
    </ol>
  </nav>

  <div class="content-frame">
    <article class="media-card">
      <div class="media-poster">
        {% if image %}
          <img src="{{ image }}" alt="Poster de {{ title }}" class="media-poster-img" loading="lazy">
        {% else %}
          <div class="media-poster-placeholder" aria-label="Sem poster disponível">
            <span>🎬</span>
          </div>
        {% endif %}
      </div>

      <div class="media-info">
        <h1 class="media-title">{{ title }}</h1>

        <dl class="media-meta">
          {% if director %}
            <dt>Direção</dt>
            <dd>{{ director }}</dd>
          {% endif %}
          {% if writers %}
            <dt>Roteiro</dt>
            <dd>{{ writers }}</dd>
          {% endif %}
          {% if year %}
            <dt>Ano</dt>
            <dd>{{ year }}</dd>
          {% endif %}
          {% if country %}
            <dt>País</dt>
            <dd>{{ country }}</dd>
          {% endif %}
          {% if duration %}
            <dt>Duração</dt>
            <dd>{{ duration }} min</dd>
          {% endif %}
          {% if rating %}
            {% set r = rating | int %}
            <dt>Avaliação</dt>
            <dd class="media-rating" aria-label="{{ r }} de 5 estrelas">{% for i in range(r) %}★{% endfor %}{% for i in range(5 - r) %}☆{% endfor %}</dd>
          {% endif %}
        </dl>

        {% if tags %}
          <ul class="media-tags" aria-label="Tags">
            {% for tag in tags %}
              <li class="media-tag-pill">{{ tag }}</li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>
    </article>

    {% if trailer %}
      <div class="media-trailer">
        <h2 class="media-trailer-title">Trailer</h2>
        <div class="media-trailer-embed">
          <iframe
            src="https://www.youtube.com/embed/{{ trailer }}"
            title="Trailer de {{ title }}"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
      </div>
    {% endif %}

    {% if note or content %}
      <div class="media-review">
        {% if note %}
          <p class="media-note">{{ note }}</p>
        {% endif %}
        {% if content %}
          <div class="prose">{{ content | safe }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% include "partials/share-links.njk" %}
  </div>
</div>
