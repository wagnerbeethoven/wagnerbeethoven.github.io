---
layout: layouts/base.njk
---
<section class="page-hero">
  <div class="page-hero-inner page-hero-inner--editorial">
    <div class="editorial-bar">
      <a href="/movies/" class="editorial-back" aria-label="Voltar para filmes"><i class="fa-solid fa-chevron-left" aria-hidden="true"></i></a>
      <div class="editorial-brand">
        <p class="editorial-site">{{ site.name }}</p>
        <p class="editorial-hello">Filmes</p>
      </div>
    </div>
  </div>
</section>

<section class="content-frame">
  <div class="content-surface media-page">
    <header class="entry-header-card">
      {% set breadcrumb = [{label: "Filmes", url: "/movies/"}, {label: title}] %}
      {% include "partials/breadcrumb.njk" %}
      <h1 class="entry-title">{{ title }}</h1>
      {% if director %}<p class="media-page-subtitle">{{ director }}</p>{% endif %}
    </header>

    <div class="media-detail">
      <div class="media-poster media-poster--portrait">
        {% if image %}
          <img src="{{ image }}" alt="Poster de {{ title }}" class="media-poster-img" loading="lazy">
        {% else %}
          <div class="media-poster-placeholder" aria-hidden="true">🎬</div>
        {% endif %}
      </div>

      <div class="media-detail-info">
        <dl class="media-meta">
          {% if director %}<div class="media-meta-wide"><dt>Direção</dt><dd>{{ director }}</dd></div>{% endif %}
          {% if cast %}<div class="media-meta-wide"><dt>Elenco</dt><dd>{{ cast }}</dd></div>{% endif %}
          {% if writers %}<div class="media-meta-wide"><dt>Roteiro</dt><dd>{{ writers }}</dd></div>{% endif %}
          {% if year %}<div><dt>Ano</dt><dd>{{ year }}</dd></div>{% endif %}
          {% if country %}
            <div><dt>País</dt><dd>{{ country if country is string else country | join(", ") }}</dd></div>
          {% endif %}
          {% if duration %}
            <div><dt>Duração</dt><dd>{{ duration }}{% if duration is number %} min{% endif %}</dd></div>
          {% endif %}
        </dl>

        {% if tags %}
          <ul class="inline-pills" aria-label="Tags">
            {% for tag in tags %}
              <li><a class="pill p-category" href="/tags/#tag-{{ tag | slug }}">{{ tag }}</a></li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>
    </div>

    {% set synopsisText = synopsis or (content | striptags | trim) %}
    {% if synopsisText %}
      <h2 class="media-section-title">Sinopse</h2>
      <div class="media-text-block">
        <p class="media-note">{{ synopsisText }}</p>
      </div>
    {% endif %}

    {% if trailer %}
      <h2 class="media-section-title">Trailer</h2>
      <div class="media-trailer">
        <iframe
          src="https://www.youtube.com/embed/{{ trailer }}"
          title="Trailer de {{ title }}"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
    {% endif %}

    {% if note %}<p class="media-note">{{ note }}</p>{% endif %}
    {% if content and synopsis %}<div class="prose">{{ content | safe }}</div>{% endif %}

    {% include "partials/share-links.njk" %}
  </div>
</section>
