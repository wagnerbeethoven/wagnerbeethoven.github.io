---
layout: layouts/base.njk
---
<section class="page-hero">
  <div class="page-hero-inner page-hero-inner--editorial">
    <div class="editorial-bar">
      <a href="/music/" class="editorial-back" aria-label="Voltar para música">
        <i class="fa-solid fa-chevron-left" aria-hidden="true"></i>
      </a>
      <div class="editorial-brand">
        <p class="editorial-site">{{ site.name }}</p>
        <p class="editorial-hello">Música</p>
      </div>
    </div>
  </div>
</section>

<section class="content-frame">
  <div class="content-surface media-page">
    <header class="entry-header-card">
      {% set breadcrumb = [
        {
          label: "Coleções",
          url: "/collections/"
        }, {
          label: "Música",
          url: "/music/"
        }, {
          label: title
        }
      ] %}
      {% include "partials/breadcrumb.njk" %}
      <h1 class="entry-title">{{ title }}</h1>
      {% if artist %}
        <p class="media-page-subtitle">{{ artist }}</p>
      {% endif %}
    </header>

    <div class="media-detail">
      <div class="media-poster media-poster--square">
        {% if image %}
          <img src="{{ image }}" alt="Capa de {{ title }}" class="media-poster-img" loading="lazy">
        {% else %}
          <div class="media-poster-placeholder" aria-hidden="true">🎵</div>
        {% endif %}
      </div>

      <div class="media-detail-info">
        <dl class="media-meta">
          {% if artist %}
            <div class="media-meta-wide">
              <dt>Artista</dt>
              <dd>{{ artist }}</dd>
            </div>
          {% endif %}
          {% if title %}
            <div class="media-meta-wide">
              <dt>Álbum</dt>
              <dd>{{ title }}</dd>
            </div>
          {% endif %}
          {% if label %}
            <div>
              <dt>Gravadora</dt>
              <dd>{{ label }}</dd>
            </div>
          {% endif %}
          {% if year %}
            <div>
              <dt>Ano</dt>
              <dd>{{ year }}</dd>
            </div>
          {% endif %}
          {% if tracks %}
            <div>
              <dt>Faixas</dt>
              <dd>{{ tracks }}</dd>
            </div>
          {% endif %}
        </dl>

      </div>
    </div>

    {% if tags %}
      <ul class="mb-5 inline-pills" aria-label="Tags">
        {% for tag in tags %}
          <li>
            <a class="pill p-category" href="/tags/#tag-{{ tag | slug }}">{{ tag }}</a>
          </li>
        {% endfor %}
      </ul>
    {% endif %}
    {# ── Descrição ──────────────────────────────────────────── #}
    {% if content %}
      <h2 class="media-section-title">Sobre o álbum</h2>
      <div class="media-text-block">
        <div class="prose">{{ content | safe }}</div>
      </div>
    {% endif %}

    {# ── Player ─────────────────────────────────────────────── #}
    {% if youtubeList or youtube %}
      <h2 class="media-section-title">Faixas</h2>
      <div class="album-player">
        <iframe
          src="https://www.youtube.com/embed/{% if youtubeList %}videoseries?list={{ youtubeList }}{% else %}{{ youtube }}{% endif %}"
          title="{{ title }} — {{ artist }}"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
    {% elif spotify %}
      <h2 class="media-section-title">Ouvir</h2>
      <iframe
        src="https://open.spotify.com/embed/album/{{ spotify }}?utm_source=generator&theme=0"
        width="100%"
        height="352"
        frameborder="0"
        allowfullscreen
        allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
        loading="lazy"
        style="border-radius:0.75rem;display:block"
        title="Player Spotify: {{ title }}"
      ></iframe>
    {% endif %}

    {# ── Nota pessoal + links ────────────────────────────────── #}
    {% if note %}
      <p class="media-note">{{ note }}</p>
    {% endif %}

    <div class="media-stream-links">
      {% if browseId %}
        <a href="https://music.youtube.com/browse/{{ browseId }}" class="media-stream-btn media-stream-btn--yt" target="_blank" rel="noopener" aria-label="Abrir no YouTube Music">
          <i class="fa-brands fa-youtube" aria-hidden="true"></i> YouTube Music
        </a>
      {% elif youtube %}
        <a href="https://music.youtube.com/search?q={{ title | urlencode }}+{{ artist | urlencode }}" class="media-stream-btn media-stream-btn--yt" target="_blank" rel="noopener" aria-label="Buscar no YouTube Music">
          <i class="fa-brands fa-youtube" aria-hidden="true"></i> YouTube Music
        </a>
      {% endif %}
      {% if spotify %}
        <a href="https://open.spotify.com/album/{{ spotify }}" class="media-stream-btn media-stream-btn--sp" target="_blank" rel="noopener" aria-label="Ouvir no Spotify">
          <i class="fa-brands fa-spotify" aria-hidden="true"></i> Spotify
        </a>
      {% endif %}
    </div>

    {% include "partials/share-links.njk" %}
  </div>
</section>