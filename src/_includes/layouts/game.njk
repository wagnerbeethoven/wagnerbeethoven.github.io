---
layout: layouts/base.njk
---
<section class="page-hero">
  <div class="page-hero-inner page-hero-inner--editorial">
    <div class="editorial-bar">
      <a href="/games/" class="editorial-back" aria-label="Voltar para jogos"><i class="fa-solid fa-chevron-left" aria-hidden="true"></i></a>
      <div class="editorial-brand">
        <p class="editorial-site">{{ site.name }}</p>
        <p class="editorial-hello">Jogos</p>
      </div>
    </div>
  </div>
</section>

<section class="content-frame">
  <div class="content-surface media-page">
    <header class="entry-header-card">
      {% set breadcrumb = [{label: "Jogos", url: "/games/"}, {label: title}] %}
      {% include "partials/breadcrumb.njk" %}
      <h1 class="entry-title">{{ title }}</h1>
      {% if developer %}<p class="media-page-subtitle">{{ developer }}</p>{% endif %}
      {% if platform %}
        {% set platformText = platform | lower %}
        <ul class="platform-icons" aria-label="Plataformas">
          {% if "pc" in platformText %}
            <li class="platform-icons-item" title="PC" aria-label="PC"><i class="fa-solid fa-desktop" aria-hidden="true"></i></li>
          {% endif %}
          {% if "playstation" in platformText %}
            <li class="platform-icons-item" title="PlayStation" aria-label="PlayStation"><i class="fa-brands fa-playstation" aria-hidden="true"></i></li>
          {% endif %}
          {% if "xbox" in platformText %}
            <li class="platform-icons-item" title="Xbox" aria-label="Xbox"><i class="fa-brands fa-xbox" aria-hidden="true"></i></li>
          {% endif %}
          {% if "nintendo" in platformText or "switch" in platformText %}
            <li class="platform-icons-item" title="Nintendo" aria-label="Nintendo"><i class="fa-solid fa-gamepad" aria-hidden="true"></i></li>
          {% endif %}
          {% if "ios" in platformText or "android" in platformText or "mobile" in platformText %}
            <li class="platform-icons-item" title="Mobile" aria-label="Mobile"><i class="fa-solid fa-mobile-screen-button" aria-hidden="true"></i></li>
          {% endif %}
          {% if "mac" in platformText or "linux" in platformText %}
            <li class="platform-icons-item" title="Desktop" aria-label="Desktop"><i class="fa-solid fa-laptop" aria-hidden="true"></i></li>
          {% endif %}
        </ul>
      {% endif %}
    </header>

    <div class="media-detail">
      <div class="media-poster media-poster--portrait">
        {% if image %}
          <img src="{{ image }}" alt="Capa de {{ title }}" class="media-poster-img" loading="lazy">
        {% else %}
          <div class="media-poster-placeholder" aria-hidden="true">🎮</div>
        {% endif %}
      </div>

      <div class="media-detail-info">
        <dl class="media-meta">
          {% if developer %}<div class="media-meta-wide"><dt>Desenvolvedor</dt><dd>{{ developer }}</dd></div>{% endif %}
          {% if year %}<div><dt>Ano</dt><dd>{{ year }}</dd></div>{% endif %}
        </dl>

        {% if tags %}
          <ul class="inline-pills" aria-label="Tags">
            {% for tag in tags %}
              <li><a class="pill p-category" href="/tags/{{ tag | slug }}/">{{ tag }}</a></li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>
    </div>

    {% set synopsisText = synopsis or (content | striptags | trim) %}
    {% if synopsisText %}
      <h2 class="media-section-title">Sobre o jogo</h2>
      <div class="media-text-block">
        <p class="media-note">{{ synopsisText }}</p>
      </div>
    {% endif %}

    {% if trailer %}
      <h2 class="media-section-title">Trailer</h2>
      <div class="media-trailer">
        {% if ".mp4" in trailer or ".webm" in trailer %}
          <video controls preload="metadata" playsinline>
            <source src="{{ trailer }}">
          </video>
        {% else %}
          {% if "youtube.com/" in trailer or "youtu.be/" in trailer or "youtube-nocookie.com/" in trailer %}
            {% set trailerSrc = trailer %}
          {% else %}
            {% set trailerSrc = "https://www.youtube.com/embed/" + trailer %}
          {% endif %}
          <iframe
            src="{{ trailerSrc }}"
            title="Trailer de {{ title }}"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        {% endif %}
      </div>
    {% endif %}

    {% if note %}<p class="media-note">{{ note }}</p>{% endif %}
    {% if content and synopsis %}<div class="prose">{{ content | safe }}</div>{% endif %}

    {% include "partials/share-links.njk" %}
  </div>
</section>
