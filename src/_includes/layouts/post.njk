---
layout: layouts/base.njk
---
<section class="page-hero">
  <div class="page-hero-inner page-hero-inner--editorial">
    <div class="editorial-bar">
      <a href="/" class="editorial-back" aria-label="Voltar para a pagina inicial"><i class="fa-solid fa-chevron-left" aria-hidden="true"></i></a>
      <div class="editorial-brand">
        <p class="editorial-site">{{ site.name }}</p>
        <p class="editorial-hello">Ola, sou {{ author or site.author }}!</p>
      </div>
    </div>
  </div>
</section>

<section class="content-frame">
  <article class="content-surface h-entry">
    <header class="entry-header-card post-view-header">
      <h1 class="entry-title p-name">{{ title }}</h1>
      <p class="post-view-meta">
        Publicado por <span class="p-author">{{ author or site.author }}</span>
        {% if page.date %}<span class="entry-meta-sep" aria-hidden="true">·</span>
        <time class="dt-published" datetime="{{ page.date | htmlDateString }}">{{ page.date | relativeDate }}</time>{% endif %}
      </p>
      {% if subtitle or description %}
      <p class="entry-summary">{{ subtitle or description }}</p>
      {% endif %}
    </header>

    {% if featuredImage %}
    <figure class="post-featured-figure">
      <img class="post-featured-image u-photo" src="{{ featuredImage }}" alt="Imagem de destaque para {{ title }}" />
      {% if featuredImageCaption %}
      <figcaption class="post-featured-caption">{{ featuredImageCaption }}</figcaption>
      {% endif %}
    </figure>
    {% endif %}

    <div class="e-content prose">
      {{ content | safe }}
    </div>

    <div class="post-end-actions">
      {% if tags %}
      <div class="inline-pills">
        {% for tag in tags %}
        <a class="pill p-category" href="/tags/{{ tag | slug }}/">#{{ tag }}</a>
        {% endfor %}
      </div>
      {% endif %}
      <a href="/blog/" class="soft-link">Voltar para o arquivo</a>
    </div>

    {% include "partials/cusdis.njk" %}

    <div class="footer-meta">
      {% if location or weather %}
      <div class="post-geo-row">
        {% if location %}<span class="post-geo-location"><i class="fa-solid fa-location-dot" aria-hidden="true"></i> {{ location }}</span>{% endif %}
        {% if weather %}<span class="post-geo-weather">
          {%- if "⛈" in weather or "🌩" in weather -%}<i class="fa-solid fa-cloud-bolt" aria-hidden="true"></i>
          {%- elif "🌧" in weather or "🌦" in weather -%}<i class="fa-solid fa-cloud-rain" aria-hidden="true"></i>
          {%- elif "❄" in weather or "🌨" in weather or "⛄" in weather -%}<i class="fa-solid fa-snowflake" aria-hidden="true"></i>
          {%- elif "☀" in weather or "🌞" in weather -%}<i class="fa-solid fa-sun" aria-hidden="true"></i>
          {%- elif "⛅" in weather or "🌤" in weather -%}<i class="fa-solid fa-cloud-sun" aria-hidden="true"></i>
          {%- elif "☁" in weather or "🌥" in weather -%}<i class="fa-solid fa-cloud" aria-hidden="true"></i>
          {%- elif "🌬" in weather or "💨" in weather -%}<i class="fa-solid fa-wind" aria-hidden="true"></i>
          {%- elif "🌫" in weather or "🌁" in weather -%}<i class="fa-solid fa-smog" aria-hidden="true"></i>
          {%- else -%}<i class="fa-solid fa-cloud-sun" aria-hidden="true"></i>
          {%- endif -%}
          {{ weather }}
        </span>{% endif %}
      </div>
      {% endif %}
      {% include "partials/share-links.njk" %}
    </div>
  </article>
</section>
