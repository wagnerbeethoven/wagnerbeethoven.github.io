---
layout: layouts/base.njk
---
<section class="page-hero">
  <div class="page-hero-inner page-hero-inner--editorial">
    <div class="editorial-bar">
      <a href="/notes/" class="editorial-back" aria-label="Voltar para notas"><i class="fa-solid fa-chevron-left" aria-hidden="true"></i></a>
      <div class="editorial-brand">
        <p class="editorial-site">{{ site.name }}</p>
        <p class="editorial-hello">Notas</p>
      </div>
    </div>
  </div>
</section>

<section class="content-frame">
  <div class="content-surface">
    <header class="entry-header-card">
      {% set breadcrumb = [{label: "Notas", url: "/notes/"}, {label: title or (page.date | readableDate("dd MMM yyyy"))}] %}
      {% include "partials/breadcrumb.njk" %}
    </header>

    <article class="note-card note-card--single h-entry">
      <div class="note-card-header">
        <img class="note-card-avatar u-photo" src="/assets/profile.jpg" alt="{{ site.author }}" width="40" height="40">
        <div class="note-card-identity">
          <span class="note-card-name p-name">{{ site.author }}</span>
          <time class="note-card-handle dt-published" datetime="{{ page.date | htmlDateString }}">
            {{ page.date | readableDate("dd MMM yyyy, HH:mm") }}
          </time>
        </div>
      </div>

      <div class="note-card-body e-content prose">
        {{ content | safe }}
      </div>

      {% if tags %}
        <div class="note-card-footer">
          {% for tag in tags %}{% if tag != "notes" %}<a class="pill p-category" href="/tags/{{ tag | slug }}/">{{ tag }}</a>{% endif %}{% endfor %}
        </div>
      {% endif %}

      <a class="u-url hidden" href="{{ page.url }}">Permalink</a>
    </article>

    {% include "partials/cusdis.njk" %}
  </div>
</section>
