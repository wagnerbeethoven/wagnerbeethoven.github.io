---
layout: layouts/base.njk
---
<section class="page-hero">
  <div class="page-hero-inner page-hero-inner--editorial">
    <div class="editorial-bar">
      <a href="/notes/" class="editorial-back" aria-label="Voltar para notas"><i class="fa-solid fa-chevron-left" aria-hidden="true"></i></a>
      <div class="editorial-brand">
        <p class="editorial-site">{{ site.name }}</p>
        <p class="editorial-hello">Notas</p>
      </div>
    </div>
  </div>
</section>

<section class="content-frame">
  <div class="content-surface">
    <article class="h-entry">
      <header class="entry-header-card">
        {% set breadcrumb = [{label: "Notas", url: "/notes/"}, {label: title}] %}
        {% include "partials/breadcrumb.njk" %}
        <h1 class="entry-title p-name">{{ title }}</h1>
        {% if page.date %}
        <p class="entry-meta">
          <time class="dt-published" datetime="{{ page.date | htmlDateString }}">{{ page.date | relativeDate }}</time>
        </p>
        {% endif %}
        <a class="u-url hidden" href="{{ page.url }}">Permalink</a>
      </header>
      <div class="e-content prose">
        {{ content | safe }}
      </div>
    </article>
  </div>
</section>
