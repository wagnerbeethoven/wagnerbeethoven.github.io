---
layout: layouts/base.njk
showUpdated: true
---
<section class="page-hero">
  <div class="page-hero-inner page-hero-inner--editorial">
    <div class="editorial-bar">
      <a href="/notes/" class="editorial-back" aria-label="Voltar para notas"><i class="fa-solid fa-chevron-left" aria-hidden="true"></i></a>
      <div class="editorial-brand">
        <p class="editorial-site">{{ site.name }}</p>
        <p class="editorial-hello">Notas</p>
      </div>
    </div>
  </div>
</section>

<section class="content-frame">
  <div class="content-surface">
    <header class="entry-header-card">
      {% set breadcrumb = [{label: "Notas", url: "/notes/"}, {label: title or (page.date | readableDate("dd MMM yyyy"))}] %}
      {% include "partials/breadcrumb.njk" %}
    </header>

    <article class="note-card note-card--single h-entry">
      <a class="u-url hidden" href="{{ site.url }}{{ page.url }}">Permalink</a>
      <span class="sr-only p-author h-card">
        <a class="p-name u-url" href="{{ site.url }}" rel="me">{{ site.author }}</a>
        <a class="u-email" href="mailto:{{ site.email }}">{{ site.email }}</a>
      </span>
      <div class="note-card-header">
        <div class="note-card-identity">
          <time class="note-card-handle dt-published" datetime="{{ page.date | htmlDateString }}">
            {{ page.date | readableDate("dd/MM/yyyy") }} às {{ page.date | readableDate("HH:mm") }}
          </time>
        </div>
      </div>

      <div class="note-card-body e-content prose">
        {{ content | safe }}
      </div>
      {% if images and images | length %}
      <div class="note-card-images note-card-images--single">
        {% for img in images %}
        <img src="{{ img.fullsize or img.thumb }}" alt="{{ img.alt or '' }}" loading="lazy" class="note-card-image" />
        {% endfor %}
      </div>
      {% endif %}
      {% if link_embed and link_embed.url %}
      <a class="note-link-embed u-syndication" href="{{ link_embed.url }}" target="_blank" rel="noopener">
        {% if link_embed.thumb %}<img class="note-link-embed-thumb" src="{{ link_embed.thumb }}" alt="" loading="lazy" />{% endif %}
        <div class="note-link-embed-body">
          {% if link_embed.title %}<p class="note-link-embed-title">{{ link_embed.title }}</p>{% endif %}
          {% if link_embed.description %}<p class="note-link-embed-desc">{{ link_embed.description }}</p>{% endif %}
          <span class="note-link-embed-url">{{ link_embed.url | replace("https://", "") | replace("http://", "") | truncate(60) }}</span>
        </div>
      </a>
      {% endif %}
      {% if not bluesky_uri %}{%- include "partials/last-updated.njk" %}{% endif %}

      {% if tags %}
        <div class="note-card-footer">
          {% for tag in tags %}{% if tag != "notes" %}<a class="pill p-category" href="/tags/#tag-{{ tag | slug }}">{{ tag }}</a>{% endif %}{% endfor %}
        </div>
      {% endif %}

      <a class="u-url hidden" href="{{ page.url }}">Permalink</a>
    </article>

    {% include "partials/cusdis.njk" %}
  </div>
</section>
