---
layout: layouts/base.njk
---
<section class="page-hero">
  <div class="page-hero-inner page-hero-inner--editorial">
    <div class="editorial-bar">
      <a href="/comics/" class="editorial-back" aria-label="Voltar para quadrinhos"><i class="fa-solid fa-chevron-left" aria-hidden="true"></i></a>
      <div class="editorial-brand">
        <p class="editorial-site">{{ site.name }}</p>
        <p class="editorial-hello">Quadrinhos</p>
      </div>
    </div>
  </div>
</section>

<div class="content-surface">
  <nav class="breadcrumb" aria-label="Navegação estrutural">
    <ol class="breadcrumb-list">
      <li class="breadcrumb-item"><a href="/">Início</a></li>
      <li class="breadcrumb-item"><a href="/comics/">Quadrinhos</a></li>
      <li class="breadcrumb-item breadcrumb-item--current" aria-current="page">{{ title }}</li>
    </ol>
  </nav>

  <div class="content-frame">
    <article class="media-card">
      <div class="media-poster">
        {% if image %}
          <img src="{{ image }}" alt="Capa de {{ title }}" class="media-poster-img" loading="lazy">
        {% else %}
          <div class="media-poster-placeholder" aria-label="Sem capa disponível">
            <span>💬</span>
          </div>
        {% endif %}
      </div>

      <div class="media-info">
        <h1 class="media-title">{{ title }}</h1>

        <dl class="media-meta">
          {% if writer %}
            <dt>Roteiro</dt>
            <dd>{{ writer }}</dd>
          {% endif %}
          {% if artist %}
            <dt>Arte</dt>
            <dd>{{ artist }}</dd>
          {% endif %}
          {% if publisher %}
            <dt>Editora</dt>
            <dd>{{ publisher }}</dd>
          {% endif %}
          {% if year %}
            <dt>Ano</dt>
            <dd>{{ year }}</dd>
          {% endif %}
          {% if volumes %}
            <dt>Volumes</dt>
            <dd>{{ volumes }}</dd>
          {% endif %}
          {% if rating %}
            {% set r = rating | int %}
            <dt>Avaliação</dt>
            <dd class="media-rating" aria-label="{{ r }} de 5 estrelas">{% for i in range(r) %}★{% endfor %}{% for i in range(5 - r) %}☆{% endfor %}</dd>
          {% endif %}
        </dl>

        {% if tags %}
          <ul class="media-tags" aria-label="Tags">
            {% for tag in tags %}
              <li class="media-tag-pill">{{ tag }}</li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>
    </article>

    {% if note or content %}
      <div class="media-review">
        {% if note %}
          <p class="media-note">{{ note }}</p>
        {% endif %}
        {% if content %}
          <div class="prose">{{ content | safe }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% include "partials/share-links.njk" %}
  </div>
</div>
