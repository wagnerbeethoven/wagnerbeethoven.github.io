---
layout: layouts/base.njk
permalink: "/photos/"
title: Fotos
---
<section class="page-hero">
  <div class="page-hero-inner page-hero-inner--editorial">
    <div class="editorial-bar">
      <a href="/" class="editorial-back" aria-label="Voltar para a pagina inicial"><i class="fa-solid fa-chevron-left" aria-hidden="true"></i></a>
      <div class="editorial-brand">
        <p class="editorial-site">{{ site.name }}</p>
        <p class="editorial-hello">Fragmentos visuais</p>
      </div>
    </div>
  </div>
</section>

<section class="content-frame">
  <div class="content-surface">
    <header class="entry-header-card">
      {% set breadcrumb = [{label: "Fotos"}] %}
      {% include "partials/breadcrumb.njk" %}
      <h1 class="entry-title">Fotos</h1>
      {% include "partials/page-summary.njk" %}
    </header>

    {% set allPhotos = collections.photos | default([]) %}
    {% if allPhotos | length > 0 %}
    <div class="polaroid-grid">
      {% for item in allPhotos %}
      <figure class="polaroid">
        <img src="{{ item.data.src }}" alt="{{ item.data.alt }}" loading="lazy" />
        <figcaption class="polaroid-caption">{{ item.data.caption }}</figcaption>
      </figure>
      {% endfor %}
    </div>
    {% else %}
    <div class="empty-card">Nenhuma foto ainda.</div>
    {% endif %}
  </div>
</section>
