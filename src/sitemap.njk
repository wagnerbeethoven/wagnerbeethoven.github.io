---
layout: layouts/base.njk
permalink: "/sitemap/"
title: Mapa do site
---
<section class="page-hero">
  <div class="page-hero-inner">
    {% set breadcrumb = [{label: "Mapa do site"}] %}
      {% include "partials/breadcrumb.njk" %}
    <h1 class="page-title">Mapa do site</h1>
    <p class="page-subtitle">Um mapa completo com tudo nesse site. Explore e descubra!</p>
  </div>
</section>

<section class="content-frame">
  <div class="content-surface">

    {% set totalPosts = collections.posts | default([]) | length %}
    {% set totalNotes = collections.notes | default([]) | length %}
    {% set totalPoems = collections.poetry | default([]) | length %}
    {% set totalTags  = collections.tagList | default([]) | length %}

    <header class="entry-header-card">
      <h2 class="entry-title">Estatisticas</h2>
      <p class="entry-summary">Numeros do que foi publicado ate agora.</p>
    </header>

    <div class="grid grid-cols-2 gap-3 mb-10">
      <div class="content-surface" style="margin:0">
        <p class="text-sm text-[var(--text-secondary)] mb-1">Total de posts</p>
        <p class="text-3xl font-extrabold text-[var(--accent)]">{{ totalPosts }}</p>
      </div>
      <div class="content-surface" style="margin:0">
        <p class="text-sm text-[var(--text-secondary)] mb-1">Notas publicadas</p>
        <p class="text-3xl font-extrabold text-[var(--accent)]">{{ totalNotes }}</p>
      </div>
      <div class="content-surface" style="margin:0">
        <p class="text-sm text-[var(--text-secondary)] mb-1">Poemas</p>
        <p class="text-3xl font-extrabold text-[var(--accent)]">{{ totalPoems }}</p>
      </div>
      <div class="content-surface" style="margin:0">
        <p class="text-sm text-[var(--text-secondary)] mb-1">Tags usadas</p>
        <p class="text-3xl font-extrabold text-[var(--accent)]">{{ totalTags }}</p>
      </div>
    </div>

    {% if collections.archiveTree and collections.archiveTree.length > 0 %}
    <div class="border-t border-[var(--border-subtle)] pt-7 mb-10">
      <h2 class="text-xl font-extrabold mb-4">Posts por ano</h2>
      <div class="sidebar-list">
        {% for year in collections.archiveTree %}
        <a href="/archive/#{{ year.year }}" class="sidebar-link">
          <span>{{ year.year }}</span>
          <span class="sidebar-count">{{ year.count }} post{% if year.count != 1 %}s{% endif %}</span>
        </a>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    {% if collections.tagList and collections.tagList.length > 0 %}
    <div class="border-t border-[var(--border-subtle)] pt-7 mb-10">
      <h2 class="text-xl font-extrabold mb-4">Nuvem de tags</h2>
      <div class="inline-pills">
        {% for tag in collections.tagList %}
        <a href="/tags/{{ tag | slug }}/" class="pill">#{{ tag }}</a>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    <div class="border-t border-[var(--border-subtle)] pt-7">

      <section class="mb-8">
        <h2 class="text-xl font-extrabold mb-3">
          <i class="fa-solid fa-book-open text-[var(--accent)]" aria-hidden="true"></i> Sobre mim
        </h2>
        <div class="sidebar-list">
          <a href="/about/" class="sidebar-link"><i class="fa-regular fa-hand" aria-hidden="true"></i> Sobre</a>
          <a href="/now/" class="sidebar-link"><i class="fa-solid fa-location-dot" aria-hidden="true"></i> Agora</a>
          <a href="/contact/" class="sidebar-link"><i class="fa-solid fa-comment" aria-hidden="true"></i> Contato</a>
          <a href="/why/" class="sidebar-link"><i class="fa-solid fa-circle-question" aria-hidden="true"></i> Por que este site existe</a>
          <a href="/values/" class="sidebar-link"><i class="fa-solid fa-heart" aria-hidden="true"></i> Valores</a>
        </div>
      </section>

      <section class="mb-8 pt-6 border-t border-[var(--border-subtle)]">
        <h2 class="text-xl font-extrabold mb-3">
          <i class="fa-solid fa-user text-[var(--accent)]" aria-hidden="true"></i> Pessoal
        </h2>
        <div class="sidebar-list">
          <a href="/blog/" class="sidebar-link"><i class="fa-solid fa-pen-nib" aria-hidden="true"></i> Blog</a>
          <a href="/archive/" class="sidebar-link"><i class="fa-solid fa-calendar-days" aria-hidden="true"></i> Arquivo</a>
          <a href="/tags/" class="sidebar-link"><i class="fa-solid fa-tags" aria-hidden="true"></i> Tags</a>
          <a href="/notes/" class="sidebar-link"><i class="fa-solid fa-note-sticky" aria-hidden="true"></i> Notas</a>
          <a href="/poetry/" class="sidebar-link"><i class="fa-solid fa-feather-pointed" aria-hidden="true"></i> Poesias</a>
          <a href="/blogroll/" class="sidebar-link"><i class="fa-solid fa-rss" aria-hidden="true"></i> Blogroll</a>
        </div>
      </section>

      <section class="mb-8 pt-6 border-t border-[var(--border-subtle)]">
        <h2 class="text-xl font-extrabold mb-3">
          <i class="fa-solid fa-magnifying-glass text-[var(--accent)]" aria-hidden="true"></i> Colecoes
        </h2>
        <div class="sidebar-list">
          <a href="/bookshelf/" class="sidebar-link"><i class="fa-solid fa-book" aria-hidden="true"></i> Livros</a>
          <a href="/links/" class="sidebar-link"><i class="fa-solid fa-bookmark" aria-hidden="true"></i> Links</a>
          <a href="/movies/" class="sidebar-link"><i class="fa-solid fa-film" aria-hidden="true"></i> Filmes</a>
          <a href="/series/" class="sidebar-link"><i class="fa-solid fa-tv" aria-hidden="true"></i> Series</a>
          <a href="/games/" class="sidebar-link"><i class="fa-solid fa-gamepad" aria-hidden="true"></i> Jogos</a>
          <a href="/photos/" class="sidebar-link"><i class="fa-solid fa-camera" aria-hidden="true"></i> Fotos</a>
        </div>
      </section>

      <section class="mb-8 pt-6 border-t border-[var(--border-subtle)]">
        <h2 class="text-xl font-extrabold mb-3">
          <i class="fa-solid fa-gear text-[var(--accent)]" aria-hidden="true"></i> Ferramentas
        </h2>
        <div class="sidebar-list">
          <a href="/uses/" class="sidebar-link"><i class="fa-solid fa-laptop" aria-hidden="true"></i> O que uso</a>
          <a href="/portfolio/" class="sidebar-link"><i class="fa-solid fa-diagram-project" aria-hidden="true"></i> Projetos</a>
          <a href="/resume/" class="sidebar-link"><i class="fa-solid fa-file-lines" aria-hidden="true"></i> Curriculo</a>
        </div>
      </section>

      <section class="mb-8 pt-6 border-t border-[var(--border-subtle)]">
        <h2 class="text-xl font-extrabold mb-3">
          <i class="fa-solid fa-satellite-dish text-[var(--accent)]" aria-hidden="true"></i> Feeds
        </h2>
        <div class="sidebar-list">
          <a href="/feed.xml" class="sidebar-link"><i class="fa-solid fa-rss" style="color:#f26522" aria-hidden="true"></i> Blog: RSS/Atom</a>
        </div>
      </section>

      <section class="pt-6 border-t border-[var(--border-subtle)]">
        <h2 class="text-xl font-extrabold mb-3">
          <i class="fa-solid fa-wrench text-[var(--accent)]" aria-hidden="true"></i> Meta
        </h2>
        <div class="sidebar-list">
          <a href="/style/" class="sidebar-link"><i class="fa-solid fa-palette" aria-hidden="true"></i> Style Guide</a>
          <a href="/accessibility/" class="sidebar-link"><i class="fa-solid fa-universal-access" aria-hidden="true"></i> Acessibilidade</a>
          <a href="/colophon/" class="sidebar-link"><i class="fa-solid fa-scroll" aria-hidden="true"></i> Colofao</a>
          <a href="/sitemap/" class="sidebar-link"><i class="fa-solid fa-map" aria-hidden="true"></i> Mapa do site</a>
        </div>
      </section>

    </div>
  </div>
</section>
