---
layout: layouts/base.njk
pagination:
  data: collections.tagList
  size: 1
  alias: tag
  addAllPagesToCollections: true
permalink: /tags/{{ tag | slug }}/
eleventyComputed:
  title: "Posts tagged '{{ tag }}'"
---
<section class="page-hero">
  <div class="page-hero-inner page-hero-inner--editorial">
    <div class="editorial-bar">
      <a href="/tags/" class="editorial-back" aria-label="Voltar para tags"><i class="fa-solid fa-chevron-left" aria-hidden="true"></i></a>
      <div class="editorial-brand">
        <p class="editorial-site">{{ site.name }}</p>
        <p class="editorial-hello">Posts com a tag #{{ tag }}</p>
      </div>
    </div>
  </div>
</section>

<section class="content-frame">
  <div class="content-surface">
    <header class="entry-header-card">
      {% set breadcrumb = [{label: "Tags"}] %}
      {% include "partials/breadcrumb.njk" %}
      <h1 class="entry-title">#{{ tag }}</h1>
    </header>

    {% set currentSlug = (tag | slug) %}
    {% set taggedPosts = [] %}
    {% for post in collections.posts %}
      {% set matched = false %}
      {% if post.data.tags %}
        {% for t in post.data.tags %}
          {% if (t | slug) == currentSlug %}
            {% set matched = true %}
          {% endif %}
        {% endfor %}
      {% endif %}
      {% if matched %}
        {% set taggedPosts = (taggedPosts.push(post), taggedPosts) %}
      {% endif %}
    {% endfor %}

    {% if taggedPosts.length > 0 %}
    <div class="feed-stack">
      {% for post in taggedPosts %}
      <article class="post-card h-entry">
        <h2 class="post-card-title p-name">
          <a class="u-url" href="{{ post.url }}">{{ post.data.title or 'Sem titulo' }}</a>
        </h2>
        {% if post.date %}
        <p class="post-card-meta dt-published">{{ post.date | readableDate }}</p>
        {% endif %}
        {% if post.data.description %}
        <p class="post-card-excerpt p-summary">{{ post.data.description }}</p>
        {% endif %}
        {% if post.data.tags and post.data.tags.length > 0 %}
        <div class="post-card-footer">
          <div class="inline-pills">
            {% for postTag in post.data.tags %}
            <a href="/tags/{{ postTag | slug }}/" class="pill">#{{ postTag }}</a>
            {% endfor %}
          </div>
          <a class="read-more" href="{{ post.url }}">Ler post</a>
        </div>
        {% endif %}
      </article>
      {% endfor %}
    </div>
    {% else %}
    <div class="empty-card">
      <p class="text-[var(--text-secondary)]">Nenhum post encontrado com esta tag.</p>
    </div>
    {% endif %}
  </div>
</section>
