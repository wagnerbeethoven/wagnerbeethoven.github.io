---
layout: layouts/base.njk
permalink: "/slashes/"
title: Páginas do site
description: Todas as páginas deste site com uma breve descrição do que você encontra em cada uma.
---
<section class="page-hero">
  <div class="page-hero-inner page-hero-inner--editorial">
    <div class="editorial-bar">
      <a href="/" class="editorial-back" aria-label="Voltar para a página inicial"><i class="fa-solid fa-chevron-left" aria-hidden="true"></i></a>
      <div class="editorial-brand">
        <p class="editorial-site">{{ site.name }}</p>
        <p class="editorial-hello">Todas as páginas do site</p>
      </div>
    </div>
  </div>
</section>

<section class="content-frame">
  <div class="content-surface">
    <header class="entry-header-card">
      {% set breadcrumb = [{label: "Páginas"}] %}
      {% include "partials/breadcrumb.njk" %}
      <h1 class="entry-title">Páginas <span class="slash-title-slash">/</span></h1>
      <p class="entry-summary">
        Uma lista completa do que existe neste site — atualizada conforme o que está efetivamente publicado.
        Inspirado na convenção <a href="https://slashpages.net/" target="_blank" rel="noopener">slashpages.net</a>.
      </p>
    </header>

    {% set totalPosts = collections.posts | default([]) | length %}
    {% set totalNotes = collections.notes | default([]) | length %}
    {% set totalPoems = collections.poetry | default([]) | length %}
    {% set totalRecipes = collections.recipes | default([]) | length %}
    {% set totalPhotos = collections.photos | default([]) | length %}
    {% set totalBooks = collections.books | default([]) | length %}
    {% set totalMovies = collections.movies | default([]) | length %}
    {% set totalSeries = collections.series | default([]) | length %}
    {% set totalGames = collections.games | default([]) | length %}
    {% set totalComics = collections.comics | default([]) | length %}
    {% set totalMusic = collections.music | default([]) | length %}
    {% set totalTags = collections.tagList | default([]) | length %}

    <div class="slash-section">
      <h2 class="slash-section-title">
        <i class="fa-solid fa-user" aria-hidden="true" style="color:#5b8dd9"></i>
        Pessoal
      </h2>
      <div class="link-cards">
        <a href="/about/" class="link-card">
          <i class="fa-solid fa-user" aria-hidden="true" style="color:#5b8dd9"></i>
          <div class="link-card-body">
            <p class="link-card-title">Sobre</p>
            <p class="link-card-url">/about/</p>
            <p class="link-card-desc">Quem sou, o que faço e por onde ando.</p>
          </div>
        </a>
        <a href="/now/" class="link-card">
          <i class="fa-solid fa-location-dot" aria-hidden="true" style="color:#e05c7a"></i>
          <div class="link-card-body">
            <p class="link-card-title">Now</p>
            <p class="link-card-url">/now/</p>
            <p class="link-card-desc">O que estou fazendo, lendo e pensando agora.</p>
          </div>
        </a>
        <a href="/why/" class="link-card">
          <i class="fa-solid fa-circle-question" aria-hidden="true" style="color:#c47db8"></i>
          <div class="link-card-body">
            <p class="link-card-title">Por que este site existe</p>
            <p class="link-card-url">/why/</p>
            <p class="link-card-desc">A motivação por trás de manter um espaço próprio na web.</p>
          </div>
        </a>
        <a href="/values/" class="link-card">
          <i class="fa-solid fa-heart" aria-hidden="true" style="color:#e05c7a"></i>
          <div class="link-card-body">
            <p class="link-card-title">Valores</p>
            <p class="link-card-url">/values/</p>
            <p class="link-card-desc">Princípios que guiam meu trabalho e minha forma de estar no mundo.</p>
          </div>
        </a>
        <a href="/contact/" class="link-card">
          <i class="fa-solid fa-envelope" aria-hidden="true" style="color:#7ab87a"></i>
          <div class="link-card-body">
            <p class="link-card-title">Contato</p>
            <p class="link-card-url">/contact/</p>
            <p class="link-card-desc">Como me encontrar e falar comigo.</p>
          </div>
        </a>
      </div>
    </div>

    {% if totalPosts > 0 or totalNotes > 0 or totalPoems > 0 or totalRecipes > 0 or totalPhotos > 0 %}
    <div class="slash-section">
      <h2 class="slash-section-title">
        <i class="fa-solid fa-pen-nib" aria-hidden="true" style="color:#e07b54"></i>
        Conteúdo
      </h2>
      <div class="link-cards">
        {% if totalPosts > 0 %}
        <a href="/blog/" class="link-card">
          <i class="fa-solid fa-pen-nib" aria-hidden="true" style="color:#e07b54"></i>
          <div class="link-card-body">
            <p class="link-card-title">Blog</p>
            <p class="link-card-url">/blog/</p>
            <p class="link-card-desc">Textos longos, reflexões e leitura duradoura.</p>
          </div>
        </a>
        {% endif %}
        {% if totalNotes > 0 %}
        <a href="/notes/" class="link-card">
          <i class="fa-solid fa-note-sticky" aria-hidden="true" style="color:#f0c040"></i>
          <div class="link-card-body">
            <p class="link-card-title">Notas</p>
            <p class="link-card-url">/notes/</p>
            <p class="link-card-desc">Fragmentos, observações rápidas e ideias em rascunho.</p>
          </div>
        </a>
        {% endif %}
        {% if totalPoems > 0 %}
        <a href="/poetry/" class="link-card">
          <i class="fa-solid fa-feather-pointed" aria-hidden="true" style="color:#c47db8"></i>
          <div class="link-card-body">
            <p class="link-card-title">Poesias</p>
            <p class="link-card-url">/poetry/</p>
            <p class="link-card-desc">Textos em verso, poemas e experimentos com palavras.</p>
          </div>
        </a>
        {% endif %}
        {% if totalRecipes > 0 %}
        <a href="/recipes/" class="link-card">
          <i class="fa-solid fa-utensils" aria-hidden="true" style="color:#e0a050"></i>
          <div class="link-card-body">
            <p class="link-card-title">Receitas</p>
            <p class="link-card-url">/recipes/</p>
            <p class="link-card-desc">O que cozinho, o que aprendi e o que vale repetir.</p>
          </div>
        </a>
        {% endif %}
        {% if totalPhotos > 0 %}
        <a href="/photos/" class="link-card">
          <i class="fa-solid fa-camera" aria-hidden="true" style="color:#e05c7a"></i>
          <div class="link-card-body">
            <p class="link-card-title">Fotos</p>
            <p class="link-card-url">/photos/</p>
            <p class="link-card-desc">Fotografia: imagens que quis guardar.</p>
          </div>
        </a>
        {% endif %}
      </div>
    </div>
    {% endif %}

    {% if totalBooks > 0 or totalMovies > 0 or totalSeries > 0 or totalGames > 0 or totalComics > 0 or totalMusic > 0 %}
    <div class="slash-section">
      <h2 class="slash-section-title">
        <i class="fa-solid fa-layer-group" aria-hidden="true" style="color:#7ab87a"></i>
        Coleções
      </h2>
      <div class="link-cards">
        {% if totalBooks > 0 %}
        <a href="/bookshelf/" class="link-card">
          <i class="fa-solid fa-book" aria-hidden="true" style="color:#5b8dd9"></i>
          <div class="link-card-body">
            <p class="link-card-title">Livros</p>
            <p class="link-card-url">/bookshelf/</p>
            <p class="link-card-desc">Leituras concluídas, em andamento e lista de desejo.</p>
          </div>
        </a>
        {% endif %}
        {% if totalMovies > 0 %}
        <a href="/movies/" class="link-card">
          <i class="fa-solid fa-film" aria-hidden="true" style="color:#e05c7a"></i>
          <div class="link-card-body">
            <p class="link-card-title">Filmes</p>
            <p class="link-card-url">/movies/</p>
            <p class="link-card-desc">Cinema: o que assisti, o que ficou, o que ainda quero ver.</p>
          </div>
        </a>
        {% endif %}
        {% if totalSeries > 0 %}
        <a href="/series/" class="link-card">
          <i class="fa-solid fa-tv" aria-hidden="true" style="color:#5bc4c4"></i>
          <div class="link-card-body">
            <p class="link-card-title">Séries</p>
            <p class="link-card-url">/series/</p>
            <p class="link-card-desc">Séries que acompanho ou já terminei.</p>
          </div>
        </a>
        {% endif %}
        {% if totalGames > 0 %}
        <a href="/games/" class="link-card">
          <i class="fa-solid fa-gamepad" aria-hidden="true" style="color:#7ab87a"></i>
          <div class="link-card-body">
            <p class="link-card-title">Jogos</p>
            <p class="link-card-url">/games/</p>
            <p class="link-card-desc">Jogos zerados, em andamento e na fila.</p>
          </div>
        </a>
        {% endif %}
        {% if totalComics > 0 %}
        <a href="/comics/" class="link-card">
          <i class="fa-solid fa-book-open" aria-hidden="true" style="color:#f0c040"></i>
          <div class="link-card-body">
            <p class="link-card-title">Quadrinhos</p>
            <p class="link-card-url">/comics/</p>
            <p class="link-card-desc">Graphic novels, HQs e mangás lidos e em andamento.</p>
          </div>
        </a>
        {% endif %}
        {% if totalMusic > 0 %}
        <a href="/music/" class="link-card">
          <i class="fa-solid fa-record-vinyl" aria-hidden="true" style="color:#d51007"></i>
          <div class="link-card-body">
            <p class="link-card-title">Música</p>
            <p class="link-card-url">/music/</p>
            <p class="link-card-desc">Álbuns que marcaram, artistas que ficaram.</p>
          </div>
        </a>
        {% endif %}
      </div>
    </div>
    {% endif %}


    <div class="slash-section">
      <h2 class="slash-section-title">
        <i class="fa-solid fa-compass" aria-hidden="true" style="color:#c47db8"></i>
        Descoberta
      </h2>
      <div class="link-cards">
        {% if totalTags > 0 %}
        <a href="/tags/" class="link-card">
          <i class="fa-solid fa-tags" aria-hidden="true" style="color:#c47db8"></i>
          <div class="link-card-body">
            <p class="link-card-title">Tags</p>
            <p class="link-card-url">/tags/</p>
            <p class="link-card-desc">Todos os assuntos e marcadores usados no site.</p>
          </div>
        </a>
        {% endif %}
        <a href="/archive/" class="link-card">
          <i class="fa-solid fa-calendar-days" aria-hidden="true" style="color:#5b8dd9"></i>
          <div class="link-card-body">
            <p class="link-card-title">Arquivo</p>
            <p class="link-card-url">/archive/</p>
            <p class="link-card-desc">Histórico cronológico de tudo o que publiquei.</p>
          </div>
        </a>
        <a href="/links/" class="link-card">
          <i class="fa-solid fa-bookmark" aria-hidden="true" style="color:#f0c040"></i>
          <div class="link-card-body">
            <p class="link-card-title">Links</p>
            <p class="link-card-url">/links/</p>
            <p class="link-card-desc">Referências e lugares da web que valem revisitar.</p>
          </div>
        </a>
        <a href="/blogroll/" class="link-card">
          <i class="fa-solid fa-rss" aria-hidden="true" style="color:#f26522"></i>
          <div class="link-card-body">
            <p class="link-card-title">Blogroll</p>
            <p class="link-card-url">/blogroll/</p>
            <p class="link-card-desc">Blogs e sites que acompanho e recomendo.</p>
          </div>
        </a>
      </div>
    </div>

    <div class="slash-section">
      <h2 class="slash-section-title">
        <i class="fa-solid fa-gear" aria-hidden="true" style="color:#f0c040"></i>
        Sobre o site
      </h2>
      <div class="link-cards">
        <a href="/slashes/" class="link-card">
          <i class="fa-solid fa-slash" aria-hidden="true" style="color:#f0c040"></i>
          <div class="link-card-body">
            <p class="link-card-title">Páginas</p>
            <p class="link-card-url">/slashes/</p>
            <p class="link-card-desc">Uma lista completa do que existe neste site.</p>
          </div>
        </a>
        <a href="/changelog/" class="link-card">
          <i class="fa-solid fa-clock-rotate-left" aria-hidden="true" style="color:#7ab87a"></i>
          <div class="link-card-body">
            <p class="link-card-title">Changelog</p>
            <p class="link-card-url">/changelog/</p>
            <p class="link-card-desc">Histórico de mudanças e melhorias no site.</p>
          </div>
        </a>
        <a href="/accessibility/" class="link-card">
          <i class="fa-solid fa-universal-access" aria-hidden="true" style="color:#5b8dd9"></i>
          <div class="link-card-body">
            <p class="link-card-title">Acessibilidade</p>
            <p class="link-card-url">/accessibility/</p>
            <p class="link-card-desc">Compromissos e declaração de acessibilidade deste site.</p>
          </div>
        </a>
        <a href="/sitemap/" class="link-card">
          <i class="fa-solid fa-map" aria-hidden="true" style="color:#7ab87a"></i>
          <div class="link-card-body">
            <p class="link-card-title">Mapa do site</p>
            <p class="link-card-url">/sitemap/</p>
            <p class="link-card-desc">Visão geral de todas as páginas, seções e links publicados.</p>
          </div>
        </a>
        <a href="/colophon/" class="link-card">
          <i class="fa-solid fa-scroll" aria-hidden="true" style="color:#888"></i>
          <div class="link-card-body">
            <p class="link-card-title">Colofão</p>
            <p class="link-card-url">/colophon/</p>
            <p class="link-card-desc">Como este site é feito: tecnologia, fontes e filosofia.</p>
          </div>
        </a>
      </div>
    </div>

    <div class="slash-section">
      <h2 class="slash-section-title">
        <i class="fa-solid fa-briefcase" aria-hidden="true" style="color:#5bc4c4"></i>
        Trabalho
      </h2>
      <div class="link-cards">
        <a href="/portfolio/" class="link-card">
          <i class="fa-solid fa-diagram-project" aria-hidden="true" style="color:#5bc4c4"></i>
          <div class="link-card-body">
            <p class="link-card-title">Portfólio</p>
            <p class="link-card-url">/portfolio/</p>
            <p class="link-card-desc">Seleção de trabalhos de design e desenvolvimento.</p>
          </div>
        </a>
        <a href="/resume/" class="link-card">
          <i class="fa-solid fa-file-lines" aria-hidden="true" style="color:#888"></i>
          <div class="link-card-body">
            <p class="link-card-title">Currículo</p>
            <p class="link-card-url">/resume/</p>
            <p class="link-card-desc">Experiência profissional e formação.</p>
          </div>
        </a>
        <a href="/uses/" class="link-card">
          <i class="fa-solid fa-laptop" aria-hidden="true" style="color:#888"></i>
          <div class="link-card-body">
            <p class="link-card-title">O que uso</p>
            <p class="link-card-url">/uses/</p>
            <p class="link-card-desc">Ferramentas, apps e configurações que uso no dia a dia.</p>
          </div>
        </a>
      </div>
    </div>
  </div>
</section>
