---
layout: layouts/base.njk
permalink: "/comics/"
title: Quadrinhos
---
<section class="page-hero">
  <div class="page-hero-inner page-hero-inner--editorial">
    <div class="editorial-bar">
      <a href="/" class="editorial-back" aria-label="Voltar para a pagina inicial"><i class="fa-solid fa-chevron-left" aria-hidden="true"></i></a>
      <div class="editorial-brand">
        <p class="editorial-site">{{ site.name }}</p>
        <p class="editorial-hello">Quadrinhos e graphic novels</p>
      </div>
    </div>
  </div>
</section>

<section class="content-frame">
  <div class="content-surface">
    <header class="entry-header-card">
      {% set breadcrumb = [{label: "Quadrinhos"}] %}
      {% include "partials/breadcrumb.njk" %}
      <h1 class="entry-title">Quadrinhos</h1>
      <p class="entry-summary">Graphic novels, HQs e mangás — o que li, o que estou lendo e o que quero ler.</p>
    </header>

    {% set allComics = collections.comics | default([]) %}
    {% if allComics | length > 0 %}
    <div class="media-grid">
      {% for item in allComics %}
      <div class="media-card">
        <div class="media-card-poster">
          {{ item.data.poster or '📚' }}
          {% if item.data.status == 'read' %}<span class="media-badge media-badge--done">Lido</span>
          {% elif item.data.status == 'reading' %}<span class="media-badge media-badge--watching">Lendo</span>
          {% elif item.data.status == 'want' %}<span class="media-badge media-badge--want">Quero ler</span>
          {% endif %}
        </div>
        <div class="media-card-body">
          <p class="media-card-title">{{ item.data.title }}</p>
          <p class="media-card-meta">{{ item.data.writer }}{% if item.data.year %} · {{ item.data.year }}{% endif %}{% if item.data.volumes %} · {{ item.data.volumes }}v{% endif %}</p>
          {% if item.data.note %}<p class="media-card-note">{{ item.data.note }}</p>{% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
    {% else %}
    <div class="empty-card">Nenhum quadrinho ainda.</div>
    {% endif %}
  </div>
</section>
