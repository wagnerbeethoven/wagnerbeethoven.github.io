---
layout: layouts/base.njk
permalink: "/comics/"
title: Quadrinhos
---
<section class="page-hero">
  <div class="page-hero-inner page-hero-inner--editorial">
    <div class="editorial-bar">
      <a href="/" class="editorial-back" aria-label="Voltar para a página inicial"><i class="fa-solid fa-chevron-left" aria-hidden="true"></i></a>
      <div class="editorial-brand">
        <p class="editorial-site">{{ site.name }}</p>
        <p class="editorial-hello">Quadrinhos e graphic novels</p>
      </div>
    </div>
  </div>
</section>

<section class="content-frame">
  <div class="content-surface">
    <header class="entry-header-card">
      {% set breadcrumb = [{label: "Quadrinhos"}] %}
      {% include "partials/breadcrumb.njk" %}
      <h1 class="entry-title">Quadrinhos</h1>
      {% include "partials/page-summary.njk" %}
    </header>

    {% set allComics = collections.comics | default([]) | sort(false, false, "data.title") %}
    {% if allComics | length > 0 %}
    <div class="home-blog-list h-feed">
      {% for item in allComics %}
      <a href="{{ item.url }}" class="home-blog-row h-entry">
        <div class="home-blog-row-main">
          <span class="home-blog-row-title p-name">{{ item.data.title }}</span>
        </div>
        <span class="home-blog-row-date">{{ item.data.publisher or 'Sem editora' }}</span>
      </a>
      {% endfor %}
    </div>
    {% else %}
    <div class="empty-card">Nenhum quadrinho ainda.</div>
    {% endif %}
  </div>
</section>
