---
layout: layouts/base.njk
permalink: "/uses/"
title: O que uso
---
<section class="page-hero">
  <div class="page-hero-inner page-hero-inner--editorial">
    <div class="editorial-bar">
      <a href="/" class="editorial-back" aria-label="Voltar para a página inicial"><i class="fa-solid fa-chevron-left" aria-hidden="true"></i></a>
      <div class="editorial-brand">
        <p class="editorial-site">{{ site.name }}</p>
        <p class="editorial-hello">O que uso</p>
      </div>
    </div>
  </div>
</section>

<section class="content-frame">
  <div class="content-surface">
    <header class="entry-header-card">
      {% set breadcrumb = [{label: "O que uso"}] %}
      {% include "partials/breadcrumb.njk" %}
      <h1 class="entry-title">O que uso</h1>
      <p class="entry-summary">
        As ferramentas, tecnologias e equipamentos que sustentam meu trabalho e rotina.
        Inspirado na ideia de <a href="https://uses.tech/" target="_blank" rel="noopener">uses.tech</a>.
      </p>
    </header>

    {# ── Hardware ─────────────────────────────────────────── #}
    <div class="uses-section">
      <h2 class="uses-section-title"><i class="fa-solid fa-microchip" aria-hidden="true"></i> Hardware</h2>
      <div class="uses-grid">

        <div class="uses-card">
          <div class="uses-card-icon" style="background:color-mix(in srgb,#0078d4 12%,var(--bg-card))">
            <i class="fa-brands fa-windows" style="color:#0078d4" aria-hidden="true"></i>
          </div>
          <div class="uses-card-body">
            <p class="uses-card-name">Windows 11</p>
            <p class="uses-card-desc">Sistema operacional principal.</p>
          </div>
        </div>

        <div class="uses-card">
          <div class="uses-card-icon" style="background:color-mix(in srgb,#1428A0 12%,var(--bg-card))">
            <i class="fa-brands fa-android" style="color:#1428A0" aria-hidden="true"></i>
          </div>
          <div class="uses-card-body">
            <p class="uses-card-name">Samsung Galaxy S25 Ultra</p>
            <p class="uses-card-desc">Android. Câmera, leitura e tudo mobile.</p>
          </div>
        </div>

      </div>
    </div>

    {# ── Editor ───────────────────────────────────────────── #}
    <div class="uses-section">
      <h2 class="uses-section-title"><i class="fa-solid fa-code" aria-hidden="true"></i> Editor</h2>
      <div class="uses-grid">

        <div class="uses-card">
          <div class="uses-card-icon" style="background:color-mix(in srgb,#007acc 12%,var(--bg-card))">
            <i class="fa-solid fa-code" style="color:#007acc" aria-hidden="true"></i>
          </div>
          <div class="uses-card-body">
            <p class="uses-card-name">Visual Studio Code</p>
            <p class="uses-card-desc">Editor principal para todo o desenvolvimento.</p>
          </div>
        </div>

      </div>
    </div>

    {# ── Inteligência Artificial ──────────────────────────── #}
    <div class="uses-section">
      <h2 class="uses-section-title"><i class="fa-solid fa-robot" aria-hidden="true"></i> Inteligência Artificial</h2>
      <div class="uses-grid">

        <div class="uses-card">
          <div class="uses-card-icon" style="background:color-mix(in srgb,#d97757 12%,var(--bg-card))">
            <i class="fa-solid fa-robot" style="color:#d97757" aria-hidden="true"></i>
          </div>
          <div class="uses-card-body">
            <p class="uses-card-name">Claude (Anthropic)</p>
            <p class="uses-card-desc">Escrita, raciocínio, pesquisa e desenvolvimento deste site.</p>
          </div>
        </div>

        <div class="uses-card">
          <div class="uses-card-icon" style="background:color-mix(in srgb,#10a37f 12%,var(--bg-card))">
            <i class="fa-solid fa-brain" style="color:#10a37f" aria-hidden="true"></i>
          </div>
          <div class="uses-card-body">
            <p class="uses-card-name">OpenAI Codex / ChatGPT</p>
            <p class="uses-card-desc">Auxílio na escrita e geração de código.</p>
          </div>
        </div>

      </div>
    </div>

    {# ── Linguagens ───────────────────────────────────────── #}
    <div class="uses-section">
      <h2 class="uses-section-title"><i class="fa-solid fa-terminal" aria-hidden="true"></i> Linguagens</h2>
      <div class="uses-grid">

        <div class="uses-card">
          <div class="uses-card-icon" style="background:color-mix(in srgb,#e34c26 12%,var(--bg-card))">
            <i class="fa-brands fa-html5" style="color:#e34c26" aria-hidden="true"></i>
          </div>
          <div class="uses-card-body">
            <p class="uses-card-name">HTML</p>
            <p class="uses-card-desc">Estrutura e semântica de todo conteúdo web.</p>
          </div>
        </div>

        <div class="uses-card">
          <div class="uses-card-icon" style="background:color-mix(in srgb,#264de4 12%,var(--bg-card))">
            <i class="fa-brands fa-css3-alt" style="color:#264de4" aria-hidden="true"></i>
          </div>
          <div class="uses-card-body">
            <p class="uses-card-name">CSS</p>
            <p class="uses-card-desc">Estilização e layout com Tailwind e CSS customizado.</p>
          </div>
        </div>

        <div class="uses-card">
          <div class="uses-card-icon" style="background:color-mix(in srgb,#f7df1e 12%,var(--bg-card))">
            <i class="fa-brands fa-js" style="color:#b8a000" aria-hidden="true"></i>
          </div>
          <div class="uses-card-body">
            <p class="uses-card-name">JavaScript</p>
            <p class="uses-card-desc">Interatividade, scripts de build e lógica client-side.</p>
          </div>
        </div>

      </div>
    </div>

    {# ── Publicação e Infra ───────────────────────────────── #}
    <div class="uses-section">
      <h2 class="uses-section-title"><i class="fa-solid fa-cloud-arrow-up" aria-hidden="true"></i> Publicação e Infra</h2>
      <div class="uses-grid">

        <div class="uses-card">
          <div class="uses-card-icon" style="background:color-mix(in srgb,#00C7B7 12%,var(--bg-card))">
            <i class="fa-solid fa-cloud-arrow-up" style="color:#00C7B7" aria-hidden="true"></i>
          </div>
          <div class="uses-card-body">
            <p class="uses-card-name">Netlify</p>
            <p class="uses-card-desc">Deploy automático a cada push no GitHub.</p>
          </div>
        </div>

        <div class="uses-card">
          <div class="uses-card-icon" style="background:color-mix(in srgb,#181717 12%,var(--bg-card))">
            <i class="fa-brands fa-github" style="color:var(--text-primary)" aria-hidden="true"></i>
          </div>
          <div class="uses-card-body">
            <p class="uses-card-name">GitHub</p>
            <p class="uses-card-desc">Versionamento de código e repositório público do site.</p>
          </div>
        </div>

      </div>
    </div>

    {# ── Este site ────────────────────────────────────────── #}
    <div class="uses-section">
      <h2 class="uses-section-title"><i class="fa-solid fa-leaf" aria-hidden="true"></i> Este site</h2>
      <div class="uses-grid">

        <div class="uses-card">
          <div class="uses-card-icon" style="background:color-mix(in srgb,#c0b000 12%,var(--bg-card))">
            <i class="fa-solid fa-bolt" style="color:#c0b000" aria-hidden="true"></i>
          </div>
          <div class="uses-card-body">
            <p class="uses-card-name">Eleventy (11ty)</p>
            <p class="uses-card-desc">Gerador de site estático. Simples, rápido, sem framework.</p>
          </div>
        </div>

        <div class="uses-card">
          <div class="uses-card-icon" style="background:color-mix(in srgb,#06b6d4 12%,var(--bg-card))">
            <i class="fa-solid fa-wind" style="color:#06b6d4" aria-hidden="true"></i>
          </div>
          <div class="uses-card-body">
            <p class="uses-card-name">Tailwind CSS</p>
            <p class="uses-card-desc">Utilitários CSS para estilização rápida e consistente.</p>
          </div>
        </div>

        <div class="uses-card">
          <div class="uses-card-icon" style="background:color-mix(in srgb,#e07b54 12%,var(--bg-card))">
            <i class="fa-solid fa-file-code" style="color:#e07b54" aria-hidden="true"></i>
          </div>
          <div class="uses-card-body">
            <p class="uses-card-name">Nunjucks</p>
            <p class="uses-card-desc">Template engine para layouts, componentes e lógica de views.</p>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>
