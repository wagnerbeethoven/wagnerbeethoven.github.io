---
layout: layouts/base.njk
pagination:
  data: collections.posts
  size: 10
  alias: posts
permalink: "/blog/{% if pagination.pageNumber > 0 %}page/{{ pagination.pageNumber + 1 }}/{% endif %}"
title: Blog
showUpdated: true
---
<section class="page-hero">
  <div class="page-hero-inner page-hero-inner--editorial">
    <div class="editorial-bar">
      <a href="/" class="editorial-back" aria-label="Voltar para a pagina inicial"><i class="fa-solid fa-chevron-left" aria-hidden="true"></i></a>
      <div class="editorial-brand">
        <p class="editorial-site">{{ site.name }}</p>
        <p class="editorial-hello">Textos e reflexões</p>
      </div>
    </div>
  </div>
</section>

<section class="content-frame">
  <div class="content-surface">
    <header class="entry-header-card">
      {% set breadcrumb = [{label: "Blog"}] %}
      {% include "partials/breadcrumb.njk" %}
      <h1 class="entry-title">Blog</h1>
      <p class="entry-summary">Leitura longa, notas duráveis e arquivo pessoal.</p>
      {%- include "partials/last-updated.njk" %}
    </header>

    {% if posts | length > 0 %}
    <div class="home-grid home-grid-2 h-feed">
      {% for post in posts %}
      <a href="{{ post.url }}" class="entry-card h-entry">
        {% set thumb = post.data.banner or post.data.featuredImage %}
        {% if thumb %}
        <img class="entry-card-thumb u-featured" src="{{ thumb }}" alt="{{ post.data.title }}" loading="lazy" />
        {% endif %}
        <p class="entry-card-title p-name">{{ post.data.title }}</p>
        <p class="entry-card-meta">
          <time class="dt-published" datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time>
          · {{ post.templateContent | default('') | readingTime }} min
        </p>
        {% if post.data.description %}
        <p class="entry-card-body p-summary">{{ post.data.description | truncate(160) }}</p>
        {% endif %}
      </a>
      {% endfor %}
    </div>
    {% else %}
    <div class="empty-card">Ainda não há artigos publicados.</div>
    {% endif %}

    <nav class="utility-row mt-4" aria-label="Paginação">
      {% if pagination.href.previous %}
      <a class="soft-link" href="{{ pagination.href.previous }}">Mais recentes</a>
      {% else %}<span></span>{% endif %}
      {% if pagination.href.next %}
      <a class="soft-link" href="{{ pagination.href.next }}">Mais antigos</a>
      {% endif %}
    </nav>
  </div>
</section>
