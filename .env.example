# Copie este arquivo para .env e preencha os valores
# Nunca commite o .env — ele está no .gitignore

TMDB_KEY=           # https://www.themoviedb.org/settings/api
TMDB_TOKEN=         # Bearer token do TMDB (opcional, mesmo endpoint)
LASTFM_KEY=         # https://www.last.fm/api/account/create
LASTFM_SECRET=      # segredo Last.fm (não usado no front, só no script)
RAWG_KEY=           # https://rawg.io/apidocs (opcional)
YOUTUBE_KEY=        # console.cloud.google.com → YouTube Data API v3
